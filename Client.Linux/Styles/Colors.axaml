<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Same Discord-dark palette as the WPF client's App.xaml (BgDark/
       BgDarker/AccentBlurple/TextNormal/TextMuted) - kept as an exact hex
       match so the two clients look like the same app, not a reskin. -->
  <SolidColorBrush x:Key="BgDark" Color="#2B2D31"/>
  <SolidColorBrush x:Key="BgDarker" Color="#1E1F22"/>
  <SolidColorBrush x:Key="AccentBlurple" Color="#5865F2"/>
  <SolidColorBrush x:Key="TextNormal" Color="#DBDEE1"/>
  <SolidColorBrush x:Key="TextMuted" Color="#949BA4"/>
  <SolidColorBrush x:Key="DangerRed" Color="#F23F42"/>
</ResourceDictionary>
