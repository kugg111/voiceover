<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Voiceover.Client.Linux"
        x:Class="Voiceover.Client.Linux.MainWindow"
        Title="Voiceover" Width="1100" Height="700"
        Background="{StaticResource BgDark}">
    <Window.Styles>
        <!-- Applied via Classes.reacted="{Binding ReactedByMe}" on each
             reaction pill (see the message DataTemplate below) - avoids
             needing a bool-to-brush converter just for this one highlight. -->
        <Style Selector="Button.reacted">
            <Setter Property="Background" Value="{StaticResource AccentBlurple}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Styles>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="72"/>   <!-- server rail -->
            <ColumnDefinition Width="220"/>  <!-- channel sidebar -->
            <ColumnDefinition Width="*"/>    <!-- content -->
        </Grid.ColumnDefinitions>

        <!-- SERVER RAIL -->
        <Border Grid.Column="0" Background="{StaticResource BgDarker}">
            <DockPanel>
                <Button DockPanel.Dock="Bottom" x:Name="LogOutButton" Content="⎋" FontSize="18" Height="32" Width="48"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        Margin="12,0,12,12" Background="Transparent" Foreground="{StaticResource TextMuted}"
                        BorderThickness="0" Cursor="Hand" Click="LogOutButton_Click" ToolTip.Tip="Log out"/>
                <Button DockPanel.Dock="Bottom" x:Name="SettingsButton" Content="⚙" FontSize="18" Height="32" Width="48"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        Margin="12,0,12,0" Background="Transparent" Foreground="{StaticResource TextMuted}"
                        BorderThickness="0" Cursor="Hand" Click="SettingsButton_Click" ToolTip.Tip="Voice Settings"/>

                <Grid DockPanel.Dock="Top" Margin="12,12,12,4">
                    <Button x:Name="MessagesButton" Content="💬" FontSize="18" Height="48" Width="48"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                            Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}"
                            BorderThickness="0" Cursor="Hand" Click="MessagesButton_Click" ToolTip.Tip="Messages"/>
                    <Border x:Name="MessagesUnreadBadge" MinWidth="16" Height="16" CornerRadius="8"
                            Background="{StaticResource AccentBlurple}" Padding="4,0"
                            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-4,0"
                            IsVisible="False" IsHitTestVisible="False">
                        <TextBlock x:Name="MessagesUnreadBadgeText" Text="0" FontSize="10" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
                <Button DockPanel.Dock="Top" x:Name="FriendsButton" Content="👥" FontSize="18" Height="48" Width="48"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        Margin="12,0,12,8" Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}"
                        BorderThickness="0" Cursor="Hand" Click="FriendsButton_Click" ToolTip.Tip="Friends"/>
                <Border DockPanel.Dock="Top" Height="1" Background="{StaticResource BgSidebar}" Margin="16,0,16,8"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ServerList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:ServerListItem">
                                <Button Height="48" Width="48" Margin="12,8,12,0" Padding="0"
                                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                        Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}"
                                        BorderThickness="0" CornerRadius="24" Cursor="Hand"
                                        Click="ServerButton_Click" Tag="{Binding Id}" ToolTip.Tip="{Binding Name}">
                                    <TextBlock Text="{Binding Initial}" FontSize="18" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- CHANNEL / DM / FRIENDS SIDEBAR -->
        <Border Grid.Column="1" Background="{StaticResource BgSidebar}">
            <Grid>
                <DockPanel x:Name="ServerSidebarPanel">
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" x:Name="ServerNameText" Text="Select a server"
                                   FontWeight="Bold" FontSize="15" Foreground="{StaticResource TextNormal}"
                                   Padding="14,14,0,10" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" x:Name="MembersButton" Content="👥" FontSize="14"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                Width="28" Height="28" Margin="0,0,10,0"
                                Background="Transparent" Foreground="{StaticResource TextMuted}"
                                BorderThickness="0" Cursor="Hand" Click="MembersButton_Click" ToolTip.Tip="Members"/>
                    </Grid>

                    <!-- Must come before the ScrollViewer below in document
                         order - DockPanel.LastChildFill defaults to true, so
                         whichever child is declared LAST claims the fill
                         role and its own Dock value is ignored regardless of
                         what it's set to. Docked children (like this one)
                         need to come before the one true "fill" child. -->
                    <Border DockPanel.Dock="Bottom" x:Name="VoiceControlBar" IsVisible="False"
                            Background="{StaticResource BgDarker}" Margin="8,0,8,8" CornerRadius="8" Padding="6">
                        <Grid ColumnDefinitions="*,*,*">
                            <Button Grid.Column="0" x:Name="MuteMicButton" Content="🎤" FontSize="15"
                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                    ToolTip.Tip="Mute Mic" Height="36" Margin="3"
                                    Background="Transparent" Foreground="{StaticResource TextNormal}"
                                    BorderThickness="0" Cursor="Hand" Click="MuteMicButton_Click"/>
                            <Button Grid.Column="1" x:Name="DeafenButton" Content="🎧" FontSize="15"
                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                    ToolTip.Tip="Deafen" Height="36" Margin="3"
                                    Background="Transparent" Foreground="{StaticResource TextNormal}"
                                    BorderThickness="0" Cursor="Hand" Click="DeafenButton_Click"/>
                            <!-- A real vector icon instead of the 📞 emoji glyph -
                                 the emoji rendered incorrectly against a colored
                                 Button background in every combination tried
                                 (invisible at rest, fine on :pointerover, or
                                 stuck solid-red on hover too), something specific
                                 to FluentTheme's Button content compositing with
                                 color-emoji fonts. A Path is immune to all of
                                 that. "call_end" from Google's Material Symbols
                                 (Apache-2.0) - same hand-drawn-icon approach the
                                 WPF client already uses for its screen-share icon
                                 (see MainWindow.xaml's ScreenShareButton Canvas). -->
                            <Button Grid.Column="2" x:Name="LeaveVoiceButton"
                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                    ToolTip.Tip="Disconnect" Height="36" Margin="3" CornerRadius="18"
                                    Background="{StaticResource DangerRed}"
                                    BorderThickness="0" Cursor="Hand" Click="LeaveVoiceButton_Click">
                                <Viewbox Width="16" Height="16">
                                    <Canvas Width="960" Height="960" ClipToBounds="False">
                                        <Path Fill="White">
                                            <Path.RenderTransform>
                                                <TranslateTransform Y="960"/>
                                            </Path.RenderTransform>
                                            <Path.Data>
                                                m136 -304 -92 -90q-12 -12 -12 -28t12 -28q88 -95 203 -142.5T480 -640q118 0 232.5 47.5T916 -450q12 12 12 28t-12 28l-92 90q-11 11 -25.5 12t-26.5 -8l-116 -88q-8 -6 -12 -14t-4 -18v-114q-38 -12 -78 -19t-82 -7q-42 0 -82 7t-78 19v114q0 10 -4 18t-12 14l-116 88q-12 9 -26.5 8T136 -304Zm104 -198q-29 15 -56 34.5T128 -424l40 40 72 -56v-62Zm480 2v60l72 56 40 -38q-29 -26 -56 -45t-56 -33Zm-480 -2Zm480 2Z
                                            </Path.Data>
                                        </Path>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                        </Grid>
                    </Border>

                    <ScrollViewer>
                        <StackPanel>
                            <TextBlock Text="TEXT CHANNELS" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}" Margin="14,6,0,4"/>
                            <ItemsControl x:Name="TextChannelList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:ChannelListItem">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="{Binding DisplayName}" Tag="{Binding Id}"
                                                    Click="ChannelButton_Click" HorizontalContentAlignment="Left"
                                                    HorizontalAlignment="Stretch"
                                                    Background="Transparent" Foreground="{StaticResource TextMuted}"
                                                    BorderThickness="0" Padding="14,6" Height="32" Cursor="Hand"/>
                                            <Border Grid.Column="1" MinWidth="16" Height="16" CornerRadius="8" Margin="0,0,8,0"
                                                    Background="{StaticResource AccentBlurple}" Padding="4,0"
                                                    VerticalAlignment="Center" IsVisible="{Binding HasUnread}" IsHitTestVisible="False">
                                                <TextBlock Text="{Binding UnreadCountDisplay}" FontSize="10" FontWeight="Bold"
                                                           Foreground="White" HorizontalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="VOICE CHANNELS" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}" Margin="14,14,0,4"/>
                            <ItemsControl x:Name="VoiceChannelList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:ChannelListItem">
                                        <StackPanel>
                                            <Button Content="{Binding DisplayName}" Tag="{Binding Id}"
                                                    Click="ChannelButton_Click" HorizontalContentAlignment="Left"
                                                    HorizontalAlignment="Stretch"
                                                    Background="Transparent" Foreground="{StaticResource TextMuted}"
                                                    BorderThickness="0" Padding="14,6" Height="32" Cursor="Hand"/>
                                            <ItemsControl ItemsSource="{Binding Members}" Margin="30,0,8,4">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="local:VoiceRosterItem">
                                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                                            <TextBlock Text="{Binding Username}" FontSize="12"
                                                                       Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                                            <TextBlock Text="🔇" FontSize="10" Margin="4,0,0,0"
                                                                       IsVisible="{Binding IsMuted}" ToolTip.Tip="Muted"/>
                                                            <TextBlock Text="🎧" FontSize="10" Margin="4,0,0,0"
                                                                       IsVisible="{Binding IsDeafened}" ToolTip.Tip="Deafened"/>
                                                            <Ellipse Width="6" Height="6" Margin="4,0,0,0" VerticalAlignment="Center"
                                                                     Fill="{StaticResource AccentBlurple}" IsVisible="{Binding IsSpeaking}"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>

                <!-- DIRECT MESSAGES -->
                <DockPanel x:Name="MessagesSidebarPanel" IsVisible="False">
                    <TextBlock DockPanel.Dock="Top" Text="Direct Messages"
                               FontWeight="Bold" FontSize="15" Foreground="{StaticResource TextNormal}"
                               Padding="14,14,0,10"/>
                    <TextBox DockPanel.Dock="Top" x:Name="DmSearchBox" Height="34" Margin="10,0,10,8" Padding="8,6"
                             Background="{StaticResource BgDarker}" Foreground="{StaticResource TextNormal}"
                             BorderThickness="0" TextChanged="DmSearchBox_TextChanged"/>
                    <ItemsControl DockPanel.Dock="Top" x:Name="DmSearchResultsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:UserSearchResultItem">
                                <Button Tag="{Binding Id}" Click="DmSearchResult_Click"
                                        HorizontalContentAlignment="Left" HorizontalAlignment="Stretch"
                                        Background="Transparent" Foreground="{StaticResource TextNormal}"
                                        BorderThickness="0" Padding="14,8" Cursor="Hand">
                                    <TextBlock Text="{Binding Username}"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ScrollViewer>
                        <ItemsControl x:Name="DmConversationList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:DmConversationItem">
                                    <Button Click="DmConversation_Click" Tag="{Binding OtherUserId}"
                                            HorizontalContentAlignment="Stretch" HorizontalAlignment="Stretch"
                                            Background="Transparent" BorderThickness="0" Padding="14,8" Cursor="Hand">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14" Margin="0,0,8,0"
                                                    Background="{StaticResource BgDarker}">
                                                <TextBlock Text="{Binding Initial}" FontSize="12" FontWeight="Bold"
                                                           Foreground="{StaticResource TextNormal}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding OtherUsername}" FontWeight="Bold" Foreground="{StaticResource TextNormal}"/>
                                                <TextBlock Text="{Binding PreviewText}" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                            </StackPanel>
                                            <Border Grid.Column="2" MinWidth="16" Height="16" CornerRadius="8" Margin="8,0,0,0"
                                                    Background="{StaticResource AccentBlurple}" Padding="4,0"
                                                    VerticalAlignment="Center" IsVisible="{Binding HasUnread}" IsHitTestVisible="False">
                                                <TextBlock Text="{Binding UnreadCountDisplay}" FontSize="10" FontWeight="Bold"
                                                           Foreground="White" HorizontalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>

                <!-- FRIENDS -->
                <DockPanel x:Name="FriendsSidebarPanel" IsVisible="False">
                    <TextBlock DockPanel.Dock="Top" Text="Friends"
                               FontWeight="Bold" FontSize="15" Foreground="{StaticResource TextNormal}"
                               Padding="14,14,0,10"/>
                    <TextBox DockPanel.Dock="Top" x:Name="FriendSearchBox" Height="34" Margin="10,0,10,8" Padding="8,6"
                             Background="{StaticResource BgDarker}" Foreground="{StaticResource TextNormal}"
                             BorderThickness="0" TextChanged="FriendSearchBox_TextChanged"/>
                    <ItemsControl DockPanel.Dock="Top" x:Name="FriendSearchResultsList" Margin="0,0,0,4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:UserSearchResultItem">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Username}" Foreground="{StaticResource TextNormal}"
                                               VerticalAlignment="Center" Padding="14,8"/>
                                    <Button Grid.Column="1" Content="Add" Tag="{Binding Id}" Click="AddFriendButton_Click"
                                            Background="{StaticResource AccentBlurple}" Foreground="White"
                                            BorderThickness="0" Padding="8,2" Margin="0,0,10,0" Cursor="Hand"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ScrollViewer>
                        <StackPanel>
                            <TextBlock Text="PENDING REQUESTS" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}" Margin="14,10,0,4"/>
                            <ItemsControl x:Name="FriendRequestList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:FriendRequestItem">
                                        <Grid Margin="0,2,0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Username}" Foreground="{StaticResource TextNormal}"
                                                       VerticalAlignment="Center" Padding="14,6"/>
                                            <Button Grid.Column="1" Content="Accept" Tag="{Binding Id}" Click="FriendRequestAcceptButton_Click"
                                                    IsVisible="{Binding IsIncoming}"
                                                    Background="{StaticResource AccentBlurple}" Foreground="White"
                                                    BorderThickness="0" Padding="8,2" Margin="0,0,4,0" Cursor="Hand"/>
                                            <Button Grid.Column="2" Content="{Binding SecondaryActionLabel}" Tag="{Binding Id}" Click="FriendRequestRemoveButton_Click"
                                                    Background="{StaticResource BgDarker}" Foreground="{StaticResource TextMuted}"
                                                    BorderThickness="0" Padding="8,2" Margin="0,0,10,0" Cursor="Hand"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="ALL FRIENDS" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}" Margin="14,14,0,4"/>
                            <ItemsControl x:Name="FriendList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:FriendItem">
                                        <Button Tag="{Binding UserId}" Click="FriendListItem_Click"
                                                HorizontalContentAlignment="Left" HorizontalAlignment="Stretch"
                                                Background="Transparent" Foreground="{StaticResource TextNormal}"
                                                BorderThickness="0" Padding="14,8" Cursor="Hand">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Username}" VerticalAlignment="Center"/>
                                                <Ellipse Width="8" Height="8" Margin="6,0,0,0" VerticalAlignment="Center"
                                                         Fill="#3BA55D" IsVisible="{Binding IsOnline}" ToolTip.Tip="Online"/>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Grid>
        </Border>

        <!-- CONTENT AREA -->
        <Grid Grid.Column="2" Background="{StaticResource BgDark}">
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource BgDark}" BorderBrush="{StaticResource BgDarker}" BorderThickness="0,0,0,1">
                <TextBlock x:Name="SelectedChannelText" Text="Welcome" Foreground="{StaticResource TextNormal}"
                           FontWeight="Bold" VerticalAlignment="Center" Margin="16,0,0,0"/>
            </Border>

            <Grid Grid.Row="1">
                <StackPanel x:Name="WelcomePanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="WelcomeText" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextNormal}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="SelectedChannelSubtext"
                               Text="Messages aren't wired up in this build yet - coming in a future update."
                               FontSize="13" Foreground="{StaticResource TextMuted}"
                               HorizontalAlignment="Center" Margin="0,8,0,0" IsVisible="False"/>
                </StackPanel>

                <ScrollViewer x:Name="MessagesScrollViewer" IsVisible="False">
                    <ItemsControl x:Name="MessageList" Margin="16,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:MessageListItem">
                                <StackPanel Margin="0,6,0,6">
                                    <StackPanel.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="👍" Click="ReactionMenuItem_Click"/>
                                            <MenuItem Header="👎" Click="ReactionMenuItem_Click"/>
                                            <MenuItem Header="❤️" Click="ReactionMenuItem_Click"/>
                                            <MenuItem Header="😂" Click="ReactionMenuItem_Click"/>
                                            <MenuItem Header="😮" Click="ReactionMenuItem_Click"/>
                                            <MenuItem Header="😢" Click="ReactionMenuItem_Click"/>
                                            <MenuItem Header="🎉" Click="ReactionMenuItem_Click"/>
                                            <MenuItem Header="🔥" Click="ReactionMenuItem_Click"/>
                                            <Separator/>
                                            <MenuItem Header="Edit Message" Click="EditMessageMenuItem_Click" IsVisible="{Binding IsOwnMessage}"/>
                                            <MenuItem Header="Delete Message" Click="DeleteMessageMenuItem_Click" IsVisible="{Binding IsOwnMessage}"/>
                                        </ContextMenu>
                                    </StackPanel.ContextMenu>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding AuthorUsername}" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBlurple}" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding TimeDisplay}" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Content}" Foreground="{StaticResource TextNormal}" TextWrapping="Wrap"/>
                                    <ItemsControl ItemsSource="{Binding Reactions}" Margin="0,4,0,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="local:ReactionItem">
                                                <Button Content="{Binding DisplayText}" Classes.reacted="{Binding ReactedByMe}"
                                                        Click="ReactionPill_Click" Margin="0,0,4,4" Padding="6,2" FontSize="11"
                                                        Cursor="Hand" BorderThickness="0"
                                                        Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <StackPanel Grid.Row="2" x:Name="MessageInputRow" IsVisible="False" Margin="16,0,16,16">
                <TextBlock x:Name="SendStatusText" IsVisible="False" FontSize="12" Foreground="{StaticResource DangerRed}"
                           TextWrapping="Wrap" Margin="0,0,0,6"/>
                <Border x:Name="EditBanner" IsVisible="False" Background="{StaticResource BgSidebar}"
                        CornerRadius="4" Padding="10,6" Margin="0,0,0,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Editing message" FontSize="12" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="Cancel" Click="CancelEditButton_Click"
                                Background="Transparent" Foreground="{StaticResource TextMuted}"
                                BorderThickness="0" Padding="6,0" Cursor="Hand"/>
                    </Grid>
                </Border>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="MessageInputBox" PlaceholderText="Message..."
                             Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}"
                             BorderThickness="0" Padding="10,8" KeyDown="MessageInputBox_KeyDown"/>
                    <Button Grid.Column="1" Content="Send" Margin="8,0,0,0" Padding="14,8"
                            Background="{StaticResource AccentBlurple}" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Click="SendButton_Click"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
