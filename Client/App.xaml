<Application x:Class="Voiceover.Client.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <!-- No StartupUri: OnStartup (App.xaml.cs) decides between LoginWindow
         and a restored MainWindow session at runtime. -->
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Restyles standard controls (Button, TextBox, ComboBox, etc.)
                     to the Fluent look automatically - existing XAML doesn't need
                     to switch to ui: control tags to pick this up. -->
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <!-- Discord-accurate palette - the app's only theme. -->
            <SolidColorBrush x:Key="BgDark" Color="#2B2D31"/>
            <SolidColorBrush x:Key="BgDarker" Color="#1E1F22"/>
            <SolidColorBrush x:Key="BgSidebar" Color="#232428"/>
            <SolidColorBrush x:Key="AccentBlurple" Color="#5865F2"/>
            <SolidColorBrush x:Key="TextNormal" Color="#DBDEE1"/>
            <SolidColorBrush x:Key="TextMuted" Color="#949BA4"/>
            <!-- Used only for your own voice-member row while it's still connecting
                 (see VoiceMemberItem.IsJoining) - light blue so it reads as "in
                 progress" rather than the flat gray every other row uses. -->
            <SolidColorBrush x:Key="TextJoining" Color="#8AB4F8"/>
            <!-- Destructive/error red (delete/leave buttons, error text, mute-active
                 icon) and the away/idle gold. Single source of truth: XAML consumes
                 these via {StaticResource}, C# via ThemeBrushes - previously each was
                 hand-copied as a hex literal in XAML and Color.FromRgb(...) in code. -->
            <SolidColorBrush x:Key="DangerRed" Color="#F23F42"/>
            <SolidColorBrush x:Key="AwayYellow" Color="#F0B232"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
