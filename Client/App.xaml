<Application x:Class="Voiceover.Client.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <!-- No StartupUri: OnStartup (App.xaml.cs) decides between LoginWindow
         and a restored MainWindow session at runtime. -->
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Restyles standard controls (Button, TextBox, ComboBox, etc.)
                     to the Fluent look automatically - existing XAML doesn't need
                     to switch to ui: control tags to pick this up. No
                     ui:ThemesDictionary here (used to be a hardcoded
                     Theme="Dark") - App.xaml.cs.OnStartup applies the actual
                     WPF-UI theme (and merges in DarkPalette.xaml/
                     LightPalette.xaml, this app's own custom brushes) based on
                     the saved preference, before any window is created. -->
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
