<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <UseWPF>true</UseWPF>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Voiceover.Client</RootNamespace>
    <ApplicationIcon>Assets\AppIcon.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <!-- Same headphone mark used on the landing page - .ico for the exe/
         taskbar icon, .png for in-app use (window Icon property, voice
         member avatars). -->
    <Resource Include="Assets\AppIcon.ico" />
    <Resource Include="Assets\AppIcon.png" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.SignalR.Client" Version="8.0.10" />
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.3.2" />
    <!-- Voice chat: WebRTC engine + Windows mic/speaker access.
         Pinned to the 8.0.x line, which is the last one that supports net8.0-windows -
         the 10.x releases require the .NET 10 SDK. If you install .NET 10 and want the
         newer packages instead, bump both to 10.0.x and retarget the TFM to net10.0-windows10.0.17763.0. -->
    <PackageReference Include="SIPSorcery" Version="8.0.23" />
    <PackageReference Include="SIPSorceryMedia.Windows" Version="8.0.14" />
    <!-- Already pulled in transitively by SIPSorceryMedia.Windows; pinned
         explicitly since VoiceService/AudioDeviceService reference NAudio's
         device-enumeration APIs directly for mic/speaker selection. -->
    <PackageReference Include="NAudio" Version="2.2.1" />
    <!-- Fluent Design controls/theming for a modern, Discord-like look -
         rounded window chrome, restyled standard controls (Button, TextBox,
         etc. get the new look automatically once the theme dictionaries are
         merged in App.xaml - no need to change existing control tags). -->
    <PackageReference Include="WPF-UI" Version="4.3.0" />
    <!-- DPAPI (ProtectedData) for encrypting the "remember me" session file
         at rest - not part of the base BCL, needs this package explicitly. -->
    <PackageReference Include="System.Security.Cryptography.ProtectedData" Version="8.0.0" />
  </ItemGroup>

</Project>
