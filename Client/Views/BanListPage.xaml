<UserControl x:Class="Voiceover.Client.Views.BanListPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <TextBlock DockPanel.Dock="Top" x:Name="EmptyStateText" Text="No banned users."
                   FontSize="12" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}"
                   Visibility="Collapsed" Margin="0,0,0,8"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="BanList" MaxWidth="480" HorizontalAlignment="Left">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource BgSidebar}" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Username}" FontWeight="Bold" FontSize="13"
                                               Foreground="{StaticResource AccentBlurple}"/>
                                    <TextBlock Text="{Binding ReasonDisplay}" FontSize="12"
                                               Foreground="{StaticResource TextNormal}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding DetailDisplay}" FontSize="11"
                                               Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Unban" Tag="{Binding UserId}" Click="UnbanButton_Click"
                                        VerticalAlignment="Top" Padding="8,4" FontSize="11"
                                        Background="{StaticResource BgDarker}" Foreground="{StaticResource TextNormal}"
                                        BorderThickness="0" Cursor="Hand"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
