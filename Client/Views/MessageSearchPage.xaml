<UserControl x:Class="Voiceover.Client.Views.MessageSearchPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBox x:Name="SearchBox" Width="280" Height="34" Padding="8,6"
                     Background="{StaticResource BgDarker}" Foreground="{StaticResource TextNormal}"
                     BorderThickness="0" KeyDown="SearchBox_KeyDown"/>
            <Button x:Name="SearchButton" Content="Search" Width="80" Height="34" Margin="8,0,0,0"
                    Click="SearchButton_Click"
                    Background="{StaticResource AccentBlurple}" Foreground="White" BorderThickness="0"/>
        </StackPanel>

        <TextBlock DockPanel.Dock="Top" x:Name="StatusText" FontSize="12" TextWrapping="Wrap"
                   Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ResultsList" MaxWidth="520" HorizontalAlignment="Left">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource BgSidebar}" CornerRadius="4" Padding="10,8" Margin="0,0,0,8"
                                Cursor="Hand" MouseLeftButtonUp="SearchResult_Click" ToolTip="Jump to this message">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding AuthorUsername}" FontWeight="Bold" FontSize="13"
                                               Foreground="{StaticResource AccentBlurple}" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding TimeDisplay}" FontSize="11"
                                               Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Content}" Foreground="{StaticResource TextNormal}"
                                           FontSize="13" TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
