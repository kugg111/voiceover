<ui:FluentWindow x:Class="Voiceover.Client.Views.ScreenShareViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Voiceover" Width="960" Height="600" MinWidth="320" MinHeight="240"
        Background="{StaticResource BgDarker}"
        Icon="/Assets/AppIcon.png"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar x:Name="ViewerTitleBar" Title="Screen Share" Grid.Row="0"/>

        <Image x:Name="ShareImage" Grid.Row="1" Stretch="Uniform" RenderOptions.BitmapScalingMode="Linear"/>
    </Grid>
</ui:FluentWindow>
