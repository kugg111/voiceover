<UserControl x:Class="Voiceover.Client.Views.EmojiManagementPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Voiceover.Client.Views">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="UploadEmojiButton" Content="Upload Emoji" Click="UploadEmojiButton_Click"
                    Padding="10,6" Background="{StaticResource AccentBlurple}" Foreground="White" BorderThickness="0"/>
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="12,0,0,0"
                       Foreground="{StaticResource TextMuted}" FontSize="12"/>
        </StackPanel>

        <TextBlock DockPanel.Dock="Top" x:Name="EmptyStateText" Text="No custom emoji yet."
                   FontSize="12" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}"
                   Visibility="Collapsed" Margin="0,0,0,8"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="EmojiList" MaxWidth="480" HorizontalAlignment="Left">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource BgSidebar}" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Image Grid.Column="0" local:AttachmentImageBehavior.Url="{Binding ImageUrl}"
                                       Width="28" Height="28" Margin="0,0,10,0" Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"
                                           FontSize="13" Foreground="{StaticResource TextNormal}"/>
                                <Button Grid.Column="2" Content="Delete" Tag="{Binding Id}" Click="DeleteButton_Click"
                                        Padding="8,4" FontSize="11"
                                        Background="{StaticResource BgDarker}" Foreground="{StaticResource TextNormal}"
                                        BorderThickness="0" Cursor="Hand"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
