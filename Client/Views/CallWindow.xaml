<ui:FluentWindow x:Class="Voiceover.Client.Views.CallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:Voiceover.Client.Views"
        Title="Voiceover" Width="320" SizeToContent="Height" MinHeight="0"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDark}"
        ResizeMode="NoResize"
        Icon="/Assets/AppIcon.png"
        Topmost="True"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        Closing="CallWindow_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar x:Name="DialogTitleBar" Title="Voiceover" Grid.Row="0" ShowMaximize="False" ShowMinimize="False"/>

        <StackPanel Grid.Row="1" Margin="20" HorizontalAlignment="Center">
            <local:AvatarView x:Name="OtherPartyAvatar" Size="72" HorizontalAlignment="Center" Margin="0,0,0,12"/>
            <TextBlock x:Name="OtherPartyNameText" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"
                       Foreground="{StaticResource TextNormal}" Margin="0,0,0,4"/>
            <TextBlock x:Name="StatusText" FontSize="13" HorizontalAlignment="Center"
                       Foreground="{StaticResource TextMuted}" Margin="0,0,0,16"/>

            <!-- Ringing state (incoming: Accept+Decline, outgoing: just Cancel via EndButton) -->
            <StackPanel x:Name="RingingButtonsPanel" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="AcceptButton" Content="Accept" Width="100" Height="36" Margin="0,0,8,0"
                        Background="#3BA55D" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Click="AcceptButton_Click"/>
                <Button x:Name="EndButton" Content="Decline" Width="100" Height="36"
                        Background="#F23F42" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Click="EndButton_Click"/>
            </StackPanel>

            <!-- Active call state -->
            <StackPanel x:Name="ActivePanel" Visibility="Collapsed">
                <ItemsControl x:Name="RosterList" Margin="0,0,0,12" Focusable="False">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,4" HorizontalAlignment="Center">
                                <local:AvatarView Size="28" DisplayName="{Binding Username}" ImageUrl="{Binding AvatarUrl}" Margin="0,0,8,0"/>
                                <TextBlock Text="🖥️" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"
                                           Visibility="{Binding ScreenSharingIconVisibility}" ToolTip="Sharing screen"/>
                                <TextBlock Text="{Binding Username}" FontSize="13" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextNormal}"/>
                                <Ellipse Width="8" Height="8" Margin="6,0,0,0" VerticalAlignment="Center"
                                         Fill="{StaticResource AccentBlurple}"
                                         Visibility="{Binding SpeakingDotVisibility}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="MuteButton" Content="🎤 Mute" Width="92" Height="32" Margin="0,0,6,0"
                            Background="Transparent" Foreground="{StaticResource TextMuted}"
                            BorderThickness="0" Cursor="Hand" Click="MuteButton_Click"/>
                    <Button x:Name="DeafenToggleButton" Content="🎧 Deafen" Width="92" Height="32" Margin="0,0,6,0"
                            Background="Transparent" Foreground="{StaticResource TextMuted}"
                            BorderThickness="0" Cursor="Hand" Click="DeafenToggleButton_Click"/>
                    <Button Content="Hang Up" Width="92" Height="32"
                            Background="#F23F42" Foreground="White" FontWeight="Bold"
                            BorderThickness="0" Cursor="Hand" Click="EndButton_Click"/>
                </StackPanel>

                <Button x:Name="ScreenShareButton" Content="🖥️ Share Screen" Height="32" Margin="0,8,0,0"
                        Background="Transparent" Foreground="{StaticResource TextMuted}"
                        BorderThickness="0" Cursor="Hand" Click="ScreenShareButton_Click">
                    <Button.ContextMenu>
                        <!-- Frame-rate presets from the Phase 2 spike (see the plan) - 30/60 are
                             the committed tiers, 120 is explicitly experimental/best-effort. -->
                        <ContextMenu x:Name="ScreenSharePresetMenu">
                            <MenuItem Header="30 fps (safe)" Click="ScreenShare30Fps_Click"/>
                            <MenuItem Header="60 fps (high)" Click="ScreenShare60Fps_Click"/>
                            <MenuItem Header="120 fps (experimental)" Click="ScreenShare120Fps_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
