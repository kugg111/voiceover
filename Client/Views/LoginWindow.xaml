<ui:FluentWindow x:Class="Voiceover.Client.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Voiceover - Login" Height="450" Width="360"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDark}"
        ResizeMode="NoResize"
        Icon="/Assets/AppIcon.png"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Voiceover" Grid.Row="0" ShowMaximize="False"/>

        <Grid Grid.Row="1" Margin="32">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Welcome back!" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextNormal}" Margin="0,0,0,4"/>
            <TextBlock Text="We're so excited to see you again." FontSize="13"
                       Foreground="{StaticResource TextMuted}" Margin="0,0,0,20"/>

            <TextBlock Text="USERNAME" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
            <TextBox x:Name="UsernameBox" Height="36" Padding="8,6"
                     Background="{StaticResource BgDarker}" Foreground="{StaticResource TextNormal}"
                     BorderThickness="0" Margin="0,0,0,14"/>

            <TextBlock Text="PASSWORD" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PasswordBox" Height="36" Padding="8,6"
                         Background="{StaticResource BgDarker}" Foreground="{StaticResource TextNormal}"
                         BorderThickness="0" Margin="0,0,0,14"/>

            <CheckBox x:Name="RememberMeBox" Content="Remember me" IsChecked="True"
                      Foreground="{StaticResource TextMuted}" Margin="0,0,0,14"/>

            <TextBlock x:Name="StatusText" Foreground="#F23F42" FontSize="12"
                       Margin="0,0,0,10" TextWrapping="Wrap" Visibility="Collapsed"/>

            <Button x:Name="LoginButton" Content="Log In" Height="40"
                    Background="{StaticResource AccentBlurple}" Foreground="White"
                    BorderThickness="0" FontWeight="Bold" Cursor="Hand"
                    Click="LoginButton_Click" Margin="0,0,0,8"/>

            <Button x:Name="RegisterButton" Content="Register New Account" Height="36"
                    Background="Transparent" Foreground="{StaticResource TextMuted}"
                    BorderThickness="0" Cursor="Hand" Click="RegisterButton_Click"/>
        </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
