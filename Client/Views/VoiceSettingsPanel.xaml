<UserControl x:Class="Voiceover.Client.Views.VoiceSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="Input Device (Microphone)" FontWeight="Bold"
                   Foreground="{StaticResource TextNormal}" Margin="0,0,0,6"/>
        <ComboBox x:Name="InputDeviceCombo" Height="44" FontSize="14" Margin="0,0,0,16"
                  DisplayMemberPath="Name" SelectionChanged="InputDeviceCombo_SelectionChanged"/>

        <TextBlock Text="Output Device (Speaker)" FontWeight="Bold"
                   Foreground="{StaticResource TextNormal}" Margin="0,0,0,6"/>
        <ComboBox x:Name="OutputDeviceCombo" Height="44" FontSize="14" Margin="0,0,0,16"
                  DisplayMemberPath="Name" SelectionChanged="OutputDeviceCombo_SelectionChanged"/>

        <CheckBox x:Name="NoiseSuppressionCheck" Content="Noise suppression"
                  Foreground="{StaticResource TextNormal}" FontWeight="Bold" Margin="0,0,0,4"
                  Checked="NoiseSuppressionCheck_Changed" Unchecked="NoiseSuppressionCheck_Changed"/>
        <TextBlock Text="Gates out quiet background noise (breathing, keyboard, room hum) picked up by the mic boost. May clip the very start of soft speech."
                   FontSize="11" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" Margin="0,0,0,12"/>

        <StackPanel x:Name="NoiseSuppressionBackendPanel" Visibility="Collapsed" Margin="16,0,0,16">
            <RadioButton x:Name="WebRtcApmRadio" Content="WebRTC (default)" GroupName="NoiseBackend"
                         Foreground="{StaticResource TextNormal}" Margin="0,0,0,4"
                         Checked="NoiseSuppressionBackendRadio_Changed"/>
            <RadioButton x:Name="RNNoiseRadio" Content="RNNoise" GroupName="NoiseBackend"
                         Foreground="{StaticResource TextNormal}" Margin="0,0,0,4"
                         Checked="NoiseSuppressionBackendRadio_Changed"/>
            <RadioButton x:Name="DeepFilterNetRadio" Content="DeepFilterNet (higher quality)" GroupName="NoiseBackend"
                         Foreground="{StaticResource TextNormal}" Margin="0,0,0,4"
                         Checked="NoiseSuppressionBackendRadio_Changed"/>
            <TextBlock Text="RNNoise is a lightweight neural denoiser - lighter on CPU, sometimes more aggressive on background noise. DeepFilterNet is a heavier deep-learning model that handles complex/changing noise (rain, keyboard clicks, background chatter) more cleanly, at the cost of a bit more CPU and latency. Try them and pick whichever sounds better on your mic."
                       FontSize="11" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" Margin="0,0,0,12"/>

            <StackPanel x:Name="DeepFilterOptionsPanel" Visibility="Collapsed">
                <TextBlock Text="Attenuation Limit" FontWeight="Bold"
                           Foreground="{StaticResource TextNormal}" Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <Slider x:Name="AttenuationLimitSlider" Width="200" Minimum="0" Maximum="100"
                            ValueChanged="AttenuationLimitSlider_ValueChanged"/>
                    <TextBlock x:Name="AttenuationLimitDisplay" Width="46" Margin="6,0,0,0"
                               VerticalAlignment="Center" Foreground="{StaticResource TextMuted}"/>
                </StackPanel>
                <TextBlock Text="How aggressively DeepFilterNet suppresses detected noise, in dB. Higher removes more noise but can start to affect your voice; lower is gentler."
                           FontSize="11" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}"/>
            </StackPanel>
        </StackPanel>

        <TextBlock Text="Changes take effect the next time you join a voice channel."
                   FontSize="11" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" Margin="0,0,0,16"/>

        <TextBlock Text="Voice Input Mode" FontWeight="Bold"
                   Foreground="{StaticResource TextNormal}" Margin="0,0,0,6"/>
        <RadioButton x:Name="VoiceActivityRadio" Content="Voice Activity (noise gate)" GroupName="InputMode"
                     Foreground="{StaticResource TextNormal}" Margin="0,0,0,4"
                     Checked="InputModeRadio_Changed"/>
        <RadioButton x:Name="PushToTalkRadio" Content="Push to Talk" GroupName="InputMode"
                     Foreground="{StaticResource TextNormal}" Margin="0,0,0,4"
                     Checked="InputModeRadio_Changed"/>
        <RadioButton x:Name="PushToMuteRadio" Content="Push to Mute" GroupName="InputMode"
                     Foreground="{StaticResource TextNormal}" Margin="0,0,0,8"
                     Checked="InputModeRadio_Changed"/>

        <StackPanel x:Name="HotkeyPanel" Visibility="Collapsed">
            <TextBlock Text="Hotkey" FontWeight="Bold"
                       Foreground="{StaticResource TextNormal}" Margin="0,0,0,6"/>
            <Button x:Name="HotkeyRecordButton" Height="40" Margin="0,0,0,4"
                    Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}"
                    BorderThickness="0" Click="HotkeyRecordButton_Click"/>
            <TextBlock Text="Click the button above, then press the key or mouse button you want to use (middle-click or a side button - left/right click aren't recordable). Works even while Voiceover isn't the focused window - pick something you don't press often."
                       FontSize="11" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}"/>
        </StackPanel>
    </StackPanel>
</UserControl>
