<UserControl x:Class="Voiceover.Client.Views.VoiceSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="Input Device (Microphone)" FontWeight="Bold"
                   Foreground="{StaticResource TextNormal}" Margin="0,0,0,6"/>
        <ComboBox x:Name="InputDeviceCombo" Height="44" FontSize="14" Margin="0,0,0,16"
                  DisplayMemberPath="Name" SelectionChanged="InputDeviceCombo_SelectionChanged"/>

        <TextBlock Text="Output Device (Speaker)" FontWeight="Bold"
                   Foreground="{StaticResource TextNormal}" Margin="0,0,0,6"/>
        <ComboBox x:Name="OutputDeviceCombo" Height="44" FontSize="14" Margin="0,0,0,16"
                  DisplayMemberPath="Name" SelectionChanged="OutputDeviceCombo_SelectionChanged"/>

        <CheckBox x:Name="NoiseSuppressionCheck" Content="Noise suppression"
                  Foreground="{StaticResource TextNormal}" FontWeight="Bold" Margin="0,0,0,4"
                  Checked="NoiseSuppressionCheck_Changed" Unchecked="NoiseSuppressionCheck_Changed"/>
        <TextBlock Text="Runs your mic through a real-time noise suppression model (not a simple volume gate) to remove background noise like fans, keyboards, and room hum. If it's removing too much of your voice along with the noise, try lowering Suppression Mix below instead of turning this off entirely."
                   FontSize="11" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" Margin="0,0,0,12"/>

        <StackPanel x:Name="NoiseSuppressionBackendPanel" Visibility="Collapsed" Margin="16,0,0,16">
            <RadioButton x:Name="RNNoiseRadio" Content="RNNoise (default)" GroupName="NoiseBackend"
                         Foreground="{StaticResource TextNormal}" Margin="0,0,0,4"
                         Checked="NoiseSuppressionBackendRadio_Changed"/>
            <RadioButton x:Name="Nsnet2Radio" Content="NSNet2" GroupName="NoiseBackend"
                         Foreground="{StaticResource TextNormal}" Margin="0,0,0,4"
                         Checked="NoiseSuppressionBackendRadio_Changed"/>
            <TextBlock Text="RNNoise is a lightweight neural denoiser - lighter on CPU, sometimes more aggressive on background noise. NSNet2 is a heavier ML denoiser that re-analyzes a short rolling window on every frame rather than carrying state forward, so it costs more CPU than RNNoise. Try both and pick whichever sounds better on your mic."
                       FontSize="11" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>

            <CheckBox x:Name="Nsnet2GpuCheck" Content="Run NSNet2 on GPU" Margin="20,0,0,4"
                      Foreground="{StaticResource TextNormal}"
                      Checked="Nsnet2GpuCheck_Changed" Unchecked="Nsnet2GpuCheck_Changed"/>
            <TextBlock x:Name="Nsnet2GpuHelpText" FontSize="11" TextWrapping="Wrap" Margin="20,0,0,8"
                       Foreground="{StaticResource TextMuted}"
                       Text="Uses any DirectX 12 GPU (NVIDIA/AMD/Intel), not just NVIDIA. NSNet2's model is small, so this often doesn't help - worth trying, but don't be surprised if CPU is just as fast or faster on your hardware. Falls back to CPU automatically if no compatible GPU is found."/>

            <ComboBox x:Name="GpuDeviceCombo" Width="260" HorizontalAlignment="Left" Margin="20,0,0,12"
                      DisplayMemberPath="Name" SelectionChanged="GpuDeviceCombo_SelectionChanged"/>

            <TextBlock Text="Suppression Mix" FontWeight="Bold"
                       Foreground="{StaticResource TextNormal}" Margin="0,12,0,4"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <Slider x:Name="SuppressionMixSlider" Width="200" Minimum="0" Maximum="100"
                        ValueChanged="SuppressionMixSlider_ValueChanged"/>
                <TextBlock x:Name="SuppressionMixDisplay" Width="46" Margin="6,0,0,0"
                           VerticalAlignment="Center" Foreground="{StaticResource TextMuted}"/>
            </StackPanel>
            <TextBlock x:Name="SuppressionMixHelpText" FontSize="11" TextWrapping="Wrap"
                       Foreground="{StaticResource TextMuted}" Margin="0,0,0,12"/>

            <CheckBox x:Name="VadGateCheck" Content="Voice activity gate (experimental)" Margin="0,0,0,4"
                      Foreground="{StaticResource TextNormal}"
                      Checked="VadGateCheck_Changed" Unchecked="VadGateCheck_Changed"/>
            <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"
                       Foreground="{StaticResource TextMuted}"
                       Text="Mutes confirmed-silence stretches after suppression runs, catching residual noise (fan hum, breathing) a suppressor alone lets through. Adds a small fixed delay (~140ms) to your mic while enabled, and holds a brief buffer before deciding to release audio so it doesn't clip the start of a word. Off by default - newest, least-tested part of this pipeline."/>

            <Button x:Name="TestMicButton" Content="Test Mic" Height="36" Width="160" HorizontalAlignment="Left"
                    Click="TestMicButton_Click"
                    Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}" BorderThickness="0"/>
            <TextBlock x:Name="TestMicResultText" FontSize="11" TextWrapping="Wrap"
                       Foreground="{StaticResource TextMuted}" Margin="0,6,0,0"/>
            <TextBlock Text="Records about 3 seconds from your selected input device, runs it through your current noise suppression settings above, and plays it back through your selected output device - so you can hear the effect immediately instead of needing a live call."
                       FontSize="11" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
        </StackPanel>

        <TextBlock Text="Changes take effect the next time you join a voice channel."
                   FontSize="11" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" Margin="0,0,0,16"/>

        <TextBlock Text="Voice Input Mode" FontWeight="Bold"
                   Foreground="{StaticResource TextNormal}" Margin="0,0,0,6"/>
        <RadioButton x:Name="VoiceActivityRadio" Content="Voice Activity (noise gate)" GroupName="InputMode"
                     Foreground="{StaticResource TextNormal}" Margin="0,0,0,4"
                     Checked="InputModeRadio_Changed"/>
        <RadioButton x:Name="PushToTalkRadio" Content="Push to Talk" GroupName="InputMode"
                     Foreground="{StaticResource TextNormal}" Margin="0,0,0,4"
                     Checked="InputModeRadio_Changed"/>
        <RadioButton x:Name="PushToMuteRadio" Content="Push to Mute" GroupName="InputMode"
                     Foreground="{StaticResource TextNormal}" Margin="0,0,0,8"
                     Checked="InputModeRadio_Changed"/>

        <StackPanel x:Name="HotkeyPanel" Visibility="Collapsed">
            <TextBlock Text="Hotkey" FontWeight="Bold"
                       Foreground="{StaticResource TextNormal}" Margin="0,0,0,6"/>
            <Button x:Name="HotkeyRecordButton" Height="40" Margin="0,0,0,4"
                    Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}"
                    BorderThickness="0" Click="HotkeyRecordButton_Click"/>
            <TextBlock Text="Click the button above, then press the key or mouse button you want to use (middle-click or a side button - left/right click aren't recordable). Works even while Voiceover isn't the focused window - pick something you don't press often."
                       FontSize="11" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}"/>
        </StackPanel>

        <TextBlock Text="Call Ring Timeout" FontWeight="Bold"
                   Foreground="{StaticResource TextNormal}" Margin="0,16,0,4"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
            <Slider x:Name="RingTimeoutSlider" Width="200" Minimum="10" Maximum="120" TickFrequency="10"
                    ValueChanged="RingTimeoutSlider_ValueChanged"/>
            <TextBlock x:Name="RingTimeoutDisplay" Width="46" Margin="6,0,0,0"
                       VerticalAlignment="Center" Foreground="{StaticResource TextMuted}"/>
        </StackPanel>
        <TextBlock Text="How long an outgoing private call rings before it auto-cancels as unanswered."
                   FontSize="11" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}"/>
    </StackPanel>
</UserControl>
