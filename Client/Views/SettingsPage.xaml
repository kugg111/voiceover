<UserControl x:Class="Voiceover.Client.Views.SettingsPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Voiceover.Client.Views">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- TAB RAIL -->
        <Border Grid.Column="0" Background="{StaticResource BgSidebar}">
            <StackPanel Margin="8">
                <Button x:Name="AccountTabButton" Content="My Account" Height="40" Margin="0,0,0,4"
                        Click="AccountTabButton_Click" HorizontalContentAlignment="Left" Padding="12,0" FontWeight="Bold"
                        BorderThickness="0"/>
                <Button x:Name="VoiceTabButton" Content="Sound Options" Height="40" Margin="0,0,0,4"
                        Click="VoiceTabButton_Click" HorizontalContentAlignment="Left" Padding="12,0" FontWeight="Bold"
                        BorderThickness="0"/>
                <Button x:Name="OverlayTabButton" Content="Game Overlay" Height="40" Margin="0,0,0,4"
                        Click="OverlayTabButton_Click" HorizontalContentAlignment="Left" Padding="12,0" FontWeight="Bold"
                        BorderThickness="0"/>
                <Button x:Name="UpdateTabButton" Content="Version" Height="40"
                        Click="UpdateTabButton_Click" HorizontalContentAlignment="Left" Padding="12,0" FontWeight="Bold"
                        BorderThickness="0"/>
            </StackPanel>
        </Border>

        <!-- TAB CONTENT -->
        <Grid Grid.Column="1" Margin="20">
            <ScrollViewer x:Name="AccountTabContent" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                <StackPanel MaxWidth="500" HorizontalAlignment="Left">
                    <TextBlock Text="MY ACCOUNT" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,12"/>
                    <local:AvatarView x:Name="AccountAvatarView" Size="80" HorizontalAlignment="Left" Margin="0,0,0,12"/>
                    <TextBlock x:Name="AccountUsernameText" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource TextNormal}" Margin="0,0,0,16"/>
                    <Button x:Name="ChangeAvatarButton" Content="Change Avatar" Height="40" Width="160"
                            HorizontalAlignment="Left" Click="ChangeAvatarButton_Click"
                            Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}" BorderThickness="0"/>

                    <TextBlock Text="Custom Status" FontWeight="Bold" Foreground="{StaticResource TextNormal}" Margin="0,20,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="CustomStatusBox" Width="220" Height="34" Padding="8,6" MaxLength="128"
                                 TextChanged="CustomStatusBox_TextChanged"
                                 Background="{StaticResource BgDarker}" Foreground="{StaticResource TextNormal}" BorderThickness="0"/>
                        <Button x:Name="SaveCustomStatusButton" Content="Save" Width="70" Height="34" Margin="8,0,0,0"
                                Click="SaveCustomStatusButton_Click"
                                Background="{StaticResource AccentBlurple}" Foreground="White" BorderThickness="0"/>
                    </StackPanel>
                    <TextBlock x:Name="CustomStatusCounterText" FontSize="11"
                               Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>

                    <TextBlock x:Name="AccountStatusText" FontSize="11" TextWrapping="Wrap"
                               Foreground="{StaticResource TextMuted}" Margin="0,8,0,0"/>

                    <CheckBox x:Name="MinimizeToTrayCheck" Content="Minimize to tray instead of closing"
                              Foreground="{StaticResource TextNormal}" FontWeight="Bold" Margin="0,20,0,4"
                              Checked="MinimizeToTrayCheck_Changed" Unchecked="MinimizeToTrayCheck_Changed"/>
                    <TextBlock Text="When enabled, closing the window hides Voiceover to the system tray instead of exiting - notifications keep coming in while it's running in the background. Right-click the tray icon to exit for real."
                               FontSize="11" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" Margin="0,0,0,0"/>

                    <Border Height="1" Background="{StaticResource BgSidebar}" Margin="0,24,0,20"/>

                    <TextBlock Text="TWO-FACTOR AUTHENTICATION" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>
                    <TextBlock x:Name="TwoFactorStatusText" FontSize="12" TextWrapping="Wrap"
                               Foreground="{StaticResource TextNormal}" Margin="0,0,0,10"/>
                    <Button x:Name="Enable2FaButton" Content="Enable 2FA" Height="40" Width="160"
                            HorizontalAlignment="Left" Click="Enable2FaButton_Click"
                            Background="{StaticResource AccentBlurple}" Foreground="White" BorderThickness="0"/>
                    <Button x:Name="Disable2FaButton" Content="Disable 2FA" Height="40" Width="160"
                            HorizontalAlignment="Left" Click="Disable2FaButton_Click" Visibility="Collapsed"
                            Background="{StaticResource DangerRed}" Foreground="White" BorderThickness="0"/>

                    <Border Height="1" Background="{StaticResource BgSidebar}" Margin="0,24,0,20"/>

                    <TextBlock Text="BLOCKED USERS" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>
                    <TextBlock x:Name="BlockedEmptyText" Text="You haven't blocked anyone."
                               FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,0,0,8" Visibility="Collapsed"/>
                    <ItemsControl x:Name="BlockedUsersList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BgSidebar}" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Username}" FontWeight="Bold" FontSize="13"
                                                   Foreground="{StaticResource TextNormal}" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="Unblock" Tag="{Binding UserId}" Click="UnblockButton_Click"
                                                Padding="8,4" FontSize="11"
                                                Background="{StaticResource BgDarker}" Foreground="{StaticResource TextNormal}"
                                                BorderThickness="0" Cursor="Hand"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Height="1" Background="{StaticResource BgSidebar}" Margin="0,4,0,20"/>

                    <TextBlock Text="DANGER ZONE" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,12"/>
                    <Button x:Name="ExportDataButton" Content="Export My Data" Height="40" Width="180"
                            HorizontalAlignment="Left" Margin="0,0,0,8" Click="ExportDataButton_Click"
                            Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}" BorderThickness="0"/>
                    <TextBlock Text="Downloads your account profile, servers, and friends list as a JSON file. Message content isn't included - this app encrypts messages end-to-end, so the server itself never has readable copies to export."
                               FontSize="11" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" Margin="0,0,0,16"/>

                    <Button x:Name="DeleteAccountButton" Content="Delete My Account" Height="40" Width="180"
                            HorizontalAlignment="Left" Click="DeleteAccountButton_Click"
                            Background="{StaticResource DangerRed}" Foreground="White" BorderThickness="0"/>
                    <TextBlock Text="Permanently deletes your account and everything tied to it. You'll be blocked from doing this while you still own a server - transfer ownership or delete it first."
                               FontSize="11" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="VoiceTabContent" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                <local:VoiceSettingsPanel x:Name="VoicePanel" MaxWidth="500" HorizontalAlignment="Left"/>
            </ScrollViewer>

            <ScrollViewer x:Name="OverlayTabContent" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                <StackPanel MaxWidth="500" HorizontalAlignment="Left">
                    <TextBlock Text="IN-GAME OVERLAY" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>
                    <CheckBox x:Name="OverlayEnabledCheck" Content="Show a voice overlay while gaming"
                              Foreground="{StaticResource TextNormal}" FontWeight="Bold" Margin="0,0,0,4"
                              Checked="OverlayEnabledCheck_Changed" Unchecked="OverlayEnabledCheck_Changed"/>
                    <TextBlock Text="Pins a small panel to the top-left of your screen showing who's in your voice channel and who's speaking. It only appears while a fullscreen game has focus, and passes clicks straight through. Works with games set to Borderless or Windowed mode - not exclusive fullscreen."
                               FontSize="11" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" Margin="0,0,0,16"/>

                    <TextBlock Text="Background Transparency" FontWeight="Bold" Foreground="{StaticResource TextNormal}" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <Slider x:Name="OverlayTransparencySlider" Width="220" Minimum="0" Maximum="100"
                                VerticalAlignment="Center" ValueChanged="OverlayTransparencySlider_ValueChanged"/>
                        <TextBlock x:Name="OverlayTransparencyText" Width="48" Margin="8,0,0,0"
                                   VerticalAlignment="Center" Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>
                    <TextBlock Text="How see-through the overlay's backdrop is. Member names and avatars always stay fully visible."
                               FontSize="11" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" Margin="0,4,0,16"/>

                    <TextBlock Text="Toggle Hotkey" FontWeight="Bold" Foreground="{StaticResource TextNormal}" Margin="0,0,0,6"/>
                    <Button x:Name="OverlayHotkeyButton" Content="None" Height="34" Width="220" HorizontalAlignment="Left"
                            Click="OverlayHotkeyButton_Click"
                            Background="{StaticResource BgDarker}" Foreground="{StaticResource TextNormal}" BorderThickness="0"/>
                    <TextBlock Text="Press this key any time to show or hide the overlay. A function key (e.g. F8) is safest so it won't clash with in-game controls."
                               FontSize="11" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                </StackPanel>
            </ScrollViewer>

            <StackPanel x:Name="UpdateTabContent" Visibility="Collapsed">
                <TextBlock Text="UPDATES" FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>
                <TextBlock x:Name="UpdateStatusText" FontSize="12" TextWrapping="Wrap"
                           Foreground="{StaticResource TextMuted}" Margin="0,0,0,12"/>

                <Button x:Name="CheckForUpdateButton" Content="Check for Update" Height="40" Margin="0,0,0,10"
                        Click="CheckForUpdateButton_Click"
                        Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}" BorderThickness="0"/>
                <Button x:Name="InstallUpdateButton" Content="Install Update" Height="40" Margin="0,0,0,10"
                        Click="InstallUpdateButton_Click" Visibility="Collapsed" FontWeight="Bold"
                        Background="{StaticResource AccentBlurple}" Foreground="White" BorderThickness="0"/>
                <ProgressBar x:Name="UpdateProgressBar" Height="6" Minimum="0" Maximum="100"
                             Visibility="Collapsed" Foreground="{StaticResource AccentBlurple}"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
