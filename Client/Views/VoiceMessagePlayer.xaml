<UserControl x:Class="Voiceover.Client.Views.VoiceMessagePlayer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        MaxWidth="280" HorizontalAlignment="Left">
    <Border Background="{StaticResource BgSidebar}" CornerRadius="16" Padding="8,6">
        <StackPanel Orientation="Horizontal">
            <Button x:Name="PlayPauseButton" Content="&#9654;" Width="28" Height="28" Padding="0" FontSize="11"
                    Background="{StaticResource AccentBlurple}" Foreground="White" BorderThickness="0"
                    Click="PlayPauseButton_Click"/>
            <ProgressBar x:Name="ProgressBarControl" Width="120" Height="4" Minimum="0" Maximum="1" Value="0"
                         Margin="8,0,8,0" VerticalAlignment="Center" Foreground="{StaticResource AccentBlurple}"/>
            <TextBlock x:Name="TimeText" Text="0:00" FontSize="11" Foreground="{StaticResource TextMuted}"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>
