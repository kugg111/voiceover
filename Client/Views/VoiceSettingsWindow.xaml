<ui:FluentWindow x:Class="Voiceover.Client.Views.VoiceSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:Voiceover.Client.Views"
        Title="Voice Settings" Height="560" Width="380"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgDark}"
        ResizeMode="NoResize"
        Icon="/Assets/AppIcon.png"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Voice Settings" Grid.Row="0" ShowMaximize="False"/>

        <ScrollViewer Grid.Row="1" Margin="16" VerticalScrollBarVisibility="Auto">
            <local:VoiceSettingsPanel x:Name="Panel"/>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
