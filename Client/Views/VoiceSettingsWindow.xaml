<ui:FluentWindow x:Class="Voiceover.Client.Views.VoiceSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Voice Settings" Height="560" Width="380"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgDark}"
        ResizeMode="NoResize"
        Icon="/Assets/AppIcon.png"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Voice Settings" Grid.Row="0" ShowMaximize="False"/>

        <StackPanel Grid.Row="1" Margin="16">
        <TextBlock Text="Input Device (Microphone)" FontWeight="Bold"
                   Foreground="{StaticResource TextNormal}" Margin="0,0,0,6"/>
        <ComboBox x:Name="InputDeviceCombo" Height="44" FontSize="14" Margin="0,0,0,16"
                  DisplayMemberPath="Name" SelectionChanged="InputDeviceCombo_SelectionChanged"/>

        <TextBlock Text="Output Device (Speaker)" FontWeight="Bold"
                   Foreground="{StaticResource TextNormal}" Margin="0,0,0,6"/>
        <ComboBox x:Name="OutputDeviceCombo" Height="44" FontSize="14" Margin="0,0,0,16"
                  DisplayMemberPath="Name" SelectionChanged="OutputDeviceCombo_SelectionChanged"/>

        <CheckBox x:Name="NoiseSuppressionCheck" Content="Noise suppression"
                  Foreground="{StaticResource TextNormal}" FontWeight="Bold" Margin="0,0,0,4"
                  Checked="NoiseSuppressionCheck_Changed" Unchecked="NoiseSuppressionCheck_Changed"/>
        <TextBlock Text="Gates out quiet background noise (breathing, keyboard, room hum) picked up by the mic boost. May clip the very start of soft speech."
                   FontSize="11" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" Margin="0,0,0,16"/>

        <TextBlock Text="Changes take effect the next time you join a voice channel."
                   FontSize="11" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" Margin="0,0,0,16"/>

        <TextBlock Text="Voice Input Mode" FontWeight="Bold"
                   Foreground="{StaticResource TextNormal}" Margin="0,0,0,6"/>
        <RadioButton x:Name="VoiceActivityRadio" Content="Voice Activity (noise gate)" GroupName="InputMode"
                     Foreground="{StaticResource TextNormal}" Margin="0,0,0,4"
                     Checked="InputModeRadio_Changed"/>
        <RadioButton x:Name="PushToTalkRadio" Content="Push to Talk" GroupName="InputMode"
                     Foreground="{StaticResource TextNormal}" Margin="0,0,0,4"
                     Checked="InputModeRadio_Changed"/>
        <RadioButton x:Name="PushToMuteRadio" Content="Push to Mute" GroupName="InputMode"
                     Foreground="{StaticResource TextNormal}" Margin="0,0,0,8"
                     Checked="InputModeRadio_Changed"/>

        <StackPanel x:Name="HotkeyPanel" Visibility="Collapsed">
            <TextBlock Text="Hotkey" FontWeight="Bold"
                       Foreground="{StaticResource TextNormal}" Margin="0,0,0,6"/>
            <Button x:Name="HotkeyRecordButton" Height="40" Margin="0,0,0,4"
                    Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}"
                    BorderThickness="0" Click="HotkeyRecordButton_Click"/>
            <TextBlock Text="Click the button above, then press the key you want to use. Works even while Voiceover isn't the focused window - pick something you don't type often."
                       FontSize="11" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}"/>
        </StackPanel>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
