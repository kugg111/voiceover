<ui:FluentWindow x:Class="Voiceover.Client.Views.PinnedMessagesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:Voiceover.Client.Views"
        Title="Pinned Messages" Height="480" Width="420"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgDark}"
        Icon="/Assets/AppIcon.png"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Pinned Messages" Grid.Row="0" ShowMaximize="False"/>

        <DockPanel Grid.Row="1" Margin="20">
            <TextBlock DockPanel.Dock="Top" x:Name="EmptyStateText" Text="No pinned messages yet."
                       FontSize="12" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}"
                       Visibility="Collapsed" Margin="0,0,0,8"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="PinnedList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource BgSidebar}" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <local:AvatarView Grid.Column="0" Size="32" DisplayName="{Binding AuthorUsername}"
                                                       ImageUrl="{Binding AuthorAvatarUrl}" Margin="0,0,10,0" VerticalAlignment="Top"/>
                                    <StackPanel Grid.Column="1">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding AuthorUsername}" FontWeight="Bold" FontSize="13"
                                                       Foreground="{StaticResource AccentBlurple}" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding TimeDisplay}" FontSize="11"
                                                       Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Content}" Foreground="{StaticResource TextNormal}"
                                                   FontSize="13" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="2" Content="Unpin" Tag="{Binding Id}" Click="UnpinButton_Click"
                                            VerticalAlignment="Top" Padding="8,4" FontSize="11"
                                            Background="{StaticResource BgDarker}" Foreground="{StaticResource TextNormal}"
                                            BorderThickness="0" Cursor="Hand" Visibility="{Binding CanUnpinVisibility}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</ui:FluentWindow>
