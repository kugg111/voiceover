<ui:FluentWindow x:Class="Voiceover.Client.Views.MessageSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Search Messages" Height="520" Width="440"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgDark}"
        Icon="/Assets/AppIcon.png"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Search Messages" Grid.Row="0" ShowMaximize="False"/>

        <DockPanel Grid.Row="1" Margin="20">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBox x:Name="SearchBox" Width="280" Height="34" Padding="8,6"
                         Background="{StaticResource BgDarker}" Foreground="{StaticResource TextNormal}"
                         BorderThickness="0" KeyDown="SearchBox_KeyDown"/>
                <Button x:Name="SearchButton" Content="Search" Width="80" Height="34" Margin="8,0,0,0"
                        Click="SearchButton_Click"
                        Background="{StaticResource AccentBlurple}" Foreground="White" BorderThickness="0"/>
            </StackPanel>

            <TextBlock DockPanel.Dock="Top" x:Name="StatusText" FontSize="12" TextWrapping="Wrap"
                       Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ResultsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource BgSidebar}" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding AuthorUsername}" FontWeight="Bold" FontSize="13"
                                                   Foreground="{StaticResource AccentBlurple}" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding TimeDisplay}" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Content}" Foreground="{StaticResource TextNormal}"
                                               FontSize="13" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</ui:FluentWindow>
