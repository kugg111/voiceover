                <TextBlock DockPanel.Dock="Top" Text="Friends"
                           FontWeight="Bold" FontSize="15" Foreground="{StaticResource TextNormal}"
                           Padding="14,14,0,10"/>
                <TextBox DockPanel.Dock="Top" x:Name="FriendSearchBox" Height="34" Margin="10,0,10,8" Padding="8,6"
                         Background="{StaticResource BgDarker}" Foreground="{StaticResource TextNormal}"
                         BorderThickness="0" TextChanged="FriendSearchBox_TextChanged"/>
                <ItemsControl DockPanel.Dock="Top" x:Name="FriendSearchResultsList" Margin="0,0,0,4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <local:AvatarView Grid.Column="0" Size="24" DisplayName="{Binding Username}"
                                                   ImageUrl="{Binding AvatarUrl}" Margin="14,0,8,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Username}" Foreground="{StaticResource TextNormal}"
                                           VerticalAlignment="Center" Padding="0,8"/>
                                <Button Grid.Column="2" Content="Add" Tag="{Binding Id}" Click="AddFriendButton_Click"
                                        Background="{StaticResource AccentBlurple}" Foreground="White"
                                        BorderThickness="0" Padding="8,2" Margin="0,0,10,0"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ScrollViewer>
                    <StackPanel>
                        <TextBlock Text="PENDING REQUESTS" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextMuted}" Margin="14,10,0,4"/>
                        <ItemsControl x:Name="FriendRequestList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <local:AvatarView Grid.Column="0" Size="24" DisplayName="{Binding Username}"
                                                           ImageUrl="{Binding AvatarUrl}" Margin="14,0,8,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Username}" Foreground="{StaticResource TextNormal}"
                                                   VerticalAlignment="Center" Padding="0,6"/>
                                        <Button Grid.Column="2" Content="Accept" Tag="{Binding Id}"
                                                Click="FriendRequestAcceptButton_Click" Visibility="{Binding AcceptButtonVisibility}"
                                                Background="{StaticResource AccentBlurple}" Foreground="White"
                                                BorderThickness="0" Padding="8,2" Margin="0,0,4,0"/>
                                        <Button Grid.Column="3" Content="{Binding SecondaryActionLabel}" Tag="{Binding Id}"
                                                Click="FriendRequestRemoveButton_Click"
                                                Background="{StaticResource BgDarker}" Foreground="{StaticResource TextMuted}"
                                                BorderThickness="0" Padding="8,2" Margin="0,0,10,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="ALL FRIENDS" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextMuted}" Margin="14,14,0,4"/>
                        <ItemsControl x:Name="FriendList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Tag="{Binding UserId}" Click="FriendListItem_Click"
                                                HorizontalContentAlignment="Left" Background="Transparent"
                                                Foreground="{StaticResource TextNormal}" BorderThickness="0" Padding="14,8">
                                            <Button.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Block User" Tag="{Binding UserId}" Click="BlockUserMenuItem_Click"/>
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                            <StackPanel Orientation="Horizontal">
                                                <local:AvatarView Size="24" DisplayName="{Binding Username}" ImageUrl="{Binding AvatarUrl}" Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding Username}" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding CustomStatus, StringFormat=' — {0}'}" VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextMuted}" FontSize="11"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="120"
                                                           Visibility="{Binding CustomStatusVisibility}"/>
                                                <Ellipse Width="8" Height="8" Margin="6,0,0,0" VerticalAlignment="Center"
                                                         Fill="#3BA55D" Visibility="{Binding OnlineDotVisibility}" ToolTip="Online"/>
                                                <Ellipse Width="8" Height="8" Margin="6,0,0,0" VerticalAlignment="Center"
                                                         Fill="#F0B232" Visibility="{Binding AwayDotVisibility}" ToolTip="Away"/>
                                                <Ellipse Width="8" Height="8" Margin="6,0,0,0" VerticalAlignment="Center"
                                                         Fill="#80848E" Visibility="{Binding OfflineDotVisibility}" ToolTip="Offline"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="1" Tag="{Binding UserId}" Click="CallFriendButton_Click"
                                                Background="Transparent" Foreground="{StaticResource TextMuted}"
                                                BorderThickness="0" Padding="8" Cursor="Hand" ToolTip="Call"
                                                VerticalAlignment="Center" Margin="0,0,8,0">
                                            <TextBlock Text="📞" FontSize="14"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- MESSAGE AREA -->
        <Grid Grid.Column="2" Background="{StaticResource BgDark}">
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource BgDark}" BorderBrush="{StaticResource BgDarker}" BorderThickness="0,0,0,1">
                <DockPanel>
                    <TextBlock x:Name="ConnectionStatusText" DockPanel.Dock="Right" Text=""
                               Foreground="#F0B232" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button x:Name="DmCallButton" DockPanel.Dock="Right" Content="📞" ToolTip="Call" Margin="0,0,12,0"
                            Background="Transparent" Foreground="{StaticResource TextMuted}"
                            BorderThickness="0" Cursor="Hand" Visibility="Collapsed"
                            Click="DmCallButton_Click"/>
                    <Button x:Name="DmBlockUserButton" DockPanel.Dock="Right" Content="🚫" ToolTip="Block User" Margin="0,0,12,0"
                            Background="Transparent" Foreground="{StaticResource TextMuted}"
                            BorderThickness="0" Cursor="Hand" Visibility="Collapsed"
                            Click="DmBlockUserButton_Click"/>
                    <Button x:Name="PinnedMessagesButton" DockPanel.Dock="Right" Content="📌" ToolTip="Pinned Messages" Margin="0,0,12,0"
                            Background="Transparent" Foreground="{StaticResource TextMuted}"
                            BorderThickness="0" Cursor="Hand" Visibility="Collapsed"
                            Click="PinnedMessagesButton_Click"/>
                    <Button x:Name="SearchMessagesButton" DockPanel.Dock="Right" Content="🔍" ToolTip="Search Messages" Margin="0,0,12,0"
                            Background="Transparent" Foreground="{StaticResource TextMuted}"
                            BorderThickness="0" Cursor="Hand" Visibility="Collapsed"
                            Click="SearchMessagesButton_Click"/>
                    <Button x:Name="ModerationLogButton" DockPanel.Dock="Right" Content="📋" ToolTip="Moderation Log" Margin="0,0,12,0"
                            Background="Transparent" Foreground="{StaticResource TextMuted}"
                            BorderThickness="0" Cursor="Hand" Visibility="Collapsed"
                            Click="ModerationLogButton_Click"/>
                    <Button x:Name="BanListButton" DockPanel.Dock="Right" Content="🔨" ToolTip="Banned Users" Margin="0,0,12,0"
                            Background="Transparent" Foreground="{StaticResource TextMuted}"
                            BorderThickness="0" Cursor="Hand" Visibility="Collapsed"
                            Click="BanListButton_Click"/>
                    <TextBlock x:Name="ChannelNameText" Text="# select-a-channel"
                               Foreground="{StaticResource TextNormal}" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="16,0,0,0"/>
                </DockPanel>
            </Border>

            <DockPanel Grid.Row="1">
                <Button x:Name="LoadOlderMessagesButton" DockPanel.Dock="Top" Content="Load Older Messages" HorizontalAlignment="Center"
                        Margin="0,8,0,0" Padding="12,6" Visibility="Collapsed" Cursor="Hand"
                        Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}"
                        BorderThickness="0" Click="LoadOlderMessagesButton_Click"/>

                <Grid>
                <TextBlock x:Name="MessagesEmptyText" Text="No messages yet - say hi! 👋"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="14" Foreground="{StaticResource TextMuted}" Visibility="Collapsed"/>

                <!-- ListBox rather than ItemsControl - a plain ItemsControl's
                     default panel (StackPanel) realizes every item in the
                     visual tree regardless of scroll position, so a long
                     channel/DM history (especially after several "load older"
                     pages) keeps costing more to lay out and render the
                     further it grows. ListBox's default panel is a
                     VirtualizingStackPanel wired to its own internal
                     ScrollViewer, so off-screen rows are actually virtualized
                     - but that internal ScrollViewer means MainWindow.xaml.cs
                     can no longer reference a MessageScroll element directly;
                     see GetMessageListScrollViewer(), which finds it once via
                     VisualTreeHelper and reuses the same ScrollToEnd/
                     ExtentHeight/ScrollToVerticalOffset calls that used to
                     target MessageScroll. ItemContainerStyle below strips
                     ListBoxItem's default selection/hover chrome so it's
                     visually identical to the old ItemsControl rows - nothing
                     here is meant to be selectable. -->
                <ListBox x:Name="MessageList" Padding="16,8" Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Focusable" Value="False"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <!-- Fade+slide-in on Loaded - fires once per row
                                 realization, so it plays for genuinely new
                                 messages (and, as an accepted tradeoff under
                                 virtualization, replays when a recycled row
                                 scrolls back into view - fast/subtle enough
                                 at 120ms not to be distracting either way). -->
                            <Grid x:Name="MessageRow" Margin="0,6,0,6" Background="{Binding RowBackground}"
                                  Opacity="0" RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <TranslateTransform Y="8"/>
                                </Grid.RenderTransform>
                                <Grid.Triggers>
                                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 To="1" Duration="0:0:0.12"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                 To="0" Duration="0:0:0.12">
                                                    <DoubleAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Grid.Triggers>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Reply" Tag="{Binding}" Click="ReplyMessageButton_Click"/>
                                        <MenuItem Header="Forward" Tag="{Binding}" Click="ForwardMessageButton_Click"/>
                                        <MenuItem Header="Edit Message" Tag="{Binding Id}" Click="EditMessageMenuItem_Click"
                                                  Visibility="{Binding EditMenuVisibility}"/>
                                        <MenuItem Header="Delete Message" Tag="{Binding Id}" Click="DeleteMessageMenuItem_Click"
                                                  Visibility="{Binding DeleteMenuVisibility}"/>
                                        <MenuItem Header="Pin Message" Tag="{Binding Id}" Click="PinMessageMenuItem_Click"
                                                  Visibility="{Binding PinMenuVisibility}"/>
                                        <MenuItem Header="Unpin Message" Tag="{Binding Id}" Click="UnpinMessageMenuItem_Click"
                                                  Visibility="{Binding UnpinMenuVisibility}"/>
                                    </ContextMenu>
                                </Grid.ContextMenu>
                                <local:AvatarView Grid.Column="0" Size="36" DisplayName="{Binding AuthorUsername}"
                                                   ImageUrl="{Binding AuthorAvatarUrl}" Margin="0,2,10,0" VerticalAlignment="Top"/>
                                <!-- Quicker alternative to the right-click context menu above - only
                                     shown while hovering this row, same as Discord's own hover actions,
                                     so the row doesn't stay visually busy with icons all the time. -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top" Margin="8,2,0,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Grid}}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Button x:Name="ReactionButton" Content="😀" Click="ReactButton_Click"
                                            ContentTemplate="{StaticResource EmojiButtonTemplate}"
                                            ToolTip="Add Reaction"
                                            Width="26" Height="26" Padding="0" Margin="0,0,4,0"
                                            Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}"
                                            BorderThickness="0" Cursor="Hand"/>
                                    <!-- Buttons in a WrapPanel rather than a ContextMenu of MenuItems -
                                         a plain Button renders as a clean, uniformly-sized square tile,
                                         which a MenuItem (styled for a vertical menu row: icon/content/
                                         shortcut/submenu-arrow columns) doesn't do well in a grid layout.
                                         IsOpen binds Mode=TwoWay so StaysOpen="False"'s own auto-dismiss
                                         (clicking elsewhere) flips MessageListItem.IsEmojiPickerOpen back
                                         without a separate close handler for that path. -->
                                    <Popup Placement="Bottom" PlacementTarget="{Binding ElementName=ReactionButton}"
                                           IsOpen="{Binding IsEmojiPickerOpen, Mode=TwoWay}" StaysOpen="False"
                                           AllowsTransparency="True" PopupAnimation="Fade"
                                           Opened="EmojiPickerPopup_Opened">
                                        <!-- Background/border/radius match ModalOverlay's card (this app's
                                             one other floating surface) rather than BgSidebar, which is
                                             the list-row color, not a popup-surface color. -->
                                        <Border Background="{StaticResource BgDark}" BorderBrush="{StaticResource BgDarker}"
                                                BorderThickness="1" CornerRadius="6" Padding="4">
                                            <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                                <WrapPanel Width="220">
                                                    <WrapPanel.Resources>
                                                        <!-- BasedOn is required - an implicit Style with none
                                                             REPLACES the app-wide WPF-UI Fluent Button style
                                                             (see App.xaml's ui:ControlsDictionary) within this
                                                             scope instead of extending it, which silently
                                                             drops its rendering/hover/corner-radius behavior. -->
                                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                            <Setter Property="Width" Value="32"/>
                                                            <Setter Property="Height" Value="32"/>
                                                            <Setter Property="Margin" Value="2"/>
                                                            <Setter Property="Padding" Value="0"/>
                                                            <Setter Property="ContentTemplate" Value="{StaticResource EmojiButtonTemplate}"/>
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                            <Setter Property="Cursor" Value="Hand"/>
                                                        </Style>
                                                    </WrapPanel.Resources>
                                                    <Button Content="👍" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="👎" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="❤️" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="😂" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="😮" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="😢" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="🎉" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="🔥" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="😀" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="😁" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="😆" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="😊" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="😍" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="🥰" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="😘" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="😜" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="🤔" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="😴" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="😭" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="😡" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="🥳" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="😎" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="🤯" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="😱" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="👏" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="🙌" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="🙏" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="💪" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="👀" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="🤝" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="✅" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="❌" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="💯" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="⭐" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="✨" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="💔" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="💕" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="🎂" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="🍕" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="☕" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="🤣" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="😅" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="🙄" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="😬" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="🤗" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="😇" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="🥺" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                    <Button Content="🫡" Tag="{Binding}" Click="ReactionMenuItem_Click"/>
                                                </WrapPanel>
                                            </ScrollViewer>
                                        </Border>
                                    </Popup>
                                    <Button Content="↩" Tag="{Binding}" Click="ReplyMessageButton_Click"
                                            ToolTip="Reply"
                                            Width="26" Height="26" Padding="0" FontSize="14" Margin="0,0,4,0"
                                            Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}"
                                            BorderThickness="0" Cursor="Hand"/>
                                    <Button Content="➡" Tag="{Binding}" Click="ForwardMessageButton_Click"
                                            ToolTip="Forward"
                                            Width="26" Height="26" Padding="0" FontSize="14" Margin="0,0,4,0"
                                            Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}"
                                            BorderThickness="0" Cursor="Hand"/>
                                    <Button Content="✏️" Tag="{Binding Id}" Click="EditMessageMenuItem_Click"
                                            Visibility="{Binding EditMenuVisibility}" ToolTip="Edit"
                                            Width="26" Height="26" Padding="0" FontSize="12" Margin="0,0,4,0"
                                            Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}"
                                            BorderThickness="0" Cursor="Hand"/>
                                    <Button Content="🗑️" Tag="{Binding Id}" Click="DeleteMessageMenuItem_Click"
                                            Visibility="{Binding DeleteMenuVisibility}" ToolTip="Delete"
                                            Width="26" Height="26" Padding="0" FontSize="12"
                                            Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}"
                                            BorderThickness="0" Cursor="Hand"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding ForwardedFromAuthorUsername, StringFormat='➡ Forwarded from {0}'}"
                                               Visibility="{Binding ForwardedBannerVisibility}"
                                               FontSize="11" FontStyle="Italic" Margin="0,0,0,2"
                                               Foreground="{StaticResource TextMuted}"/>
                                    <Border Visibility="{Binding ReplyPreviewVisibility}" Background="{StaticResource BgSidebar}"
                                            CornerRadius="3" Padding="6,3" Margin="0,0,0,4" HorizontalAlignment="Left" MaxWidth="360">
                                        <TextBlock Text="{Binding ReplyPreviewDisplay, StringFormat='↩ {0}'}" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}" TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding AuthorUsername}" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBlurple}" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding TimeDisplay}" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                        <TextBlock Text="(edited)" FontSize="11" Margin="4,0,0,0"
                                                   Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"
                                                   Visibility="{Binding EditedTagVisibility}"/>
                                        <TextBlock Text="📌 Pinned" FontSize="11" Margin="4,0,0,0"
                                                   Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"
                                                   Visibility="{Binding PinnedTagVisibility}"/>
                                    </StackPanel>
                                    <TextBlock local:FormattedTextBehavior.Content="{Binding Content}" Foreground="{StaticResource TextNormal}"
                                               TextWrapping="Wrap" Visibility="{Binding ContentVisibility}"/>
                                    <StackPanel Visibility="{Binding EditBoxVisibility}" Margin="0,2,0,0">
                                        <TextBox Text="{Binding EditingContent, UpdateSourceTrigger=PropertyChanged}"
                                                 AcceptsReturn="False" TextWrapping="Wrap"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Button Content="Save" Tag="{Binding Id}" Click="SaveMessageEditButton_Click"
                                                    Padding="10,2" Margin="0,0,6,0"/>
                                            <Button Content="Cancel" Tag="{Binding Id}" Click="CancelMessageEditButton_Click"
                                                    Padding="10,2" Background="Transparent"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Text="{Binding AttachmentDisplay}" Foreground="{StaticResource AccentBlurple}"
                                               TextDecorations="Underline" Cursor="Hand"
                                               Visibility="{Binding FileAttachmentVisibility}"
                                               MouseLeftButtonUp="AttachmentLink_MouseLeftButtonUp"
                                               Tag="{Binding AttachmentUrl}"/>
                                    <!-- Inline preview for image attachments - right-click to open the
                                         full image in the default viewer instead of always forcing a
                                         click-through-a-link-first flow. -->
                                    <Image local:AttachmentImageBehavior.Url="{Binding AttachmentFullUrl}"
                                           Visibility="{Binding ImageAttachmentVisibility}"
                                           MaxWidth="360" MaxHeight="360" Stretch="Uniform"
                                           HorizontalAlignment="Left" Margin="0,4,0,0">
                                        <Image.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Open Image" Tag="{Binding AttachmentUrl}" Click="OpenImageMenuItem_Click"/>
                                            </ContextMenu>
                                        </Image.ContextMenu>
                                    </Image>
                                    <local:VoiceMessagePlayer Url="{Binding AttachmentFullUrl}"
                                                              Visibility="{Binding VoiceAttachmentVisibility}"
                                                              Margin="0,4,0,0"/>
                                    <TextBlock Text="✓ Read" FontSize="10" Foreground="{StaticResource TextMuted}"
                                               Visibility="{Binding ReadReceiptVisibility}"/>
                                    <ItemsControl ItemsSource="{Binding Reactions}" Margin="0,4,0,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Click="ReactionPill_Click"
                                                        Padding="6,2" Margin="0,0,4,4" FontSize="12" Cursor="Hand"
                                                        BorderThickness="1">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image local:EmojiImageBehavior.Token="{Binding Emoji}"
                                                               Width="14" Height="14" Margin="0,0,4,0" Stretch="Uniform"
                                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        <TextBlock Text="{Binding Count}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Background" Value="{StaticResource BgSidebar}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource BgSidebar}"/>
                                                            <Setter Property="Foreground" Value="{StaticResource TextNormal}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ReactedByMe}" Value="True">
                                                                    <Setter Property="Background" Value="#3A3F8F"/>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBlurple}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                </Grid>
            </DockPanel>

            <StackPanel Grid.Row="2" Margin="16,0,16,16">
                <Border x:Name="ReplyBanner" Background="{StaticResource BgSidebar}" CornerRadius="4"
                        Padding="10,6" Margin="0,0,0,6" Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" x:Name="ReplyBannerText" FontSize="12"
                                   Foreground="{StaticResource TextNormal}" TextTrimming="CharacterEllipsis"/>
                        <Button Grid.Column="1" Content="✕" Click="CancelReplyButton_Click" ToolTip="Cancel reply"
                                Width="20" Height="20" Padding="0" FontSize="11"
                                Background="Transparent" Foreground="{StaticResource TextMuted}"
                                BorderThickness="0" Cursor="Hand"/>
                    </Grid>
                </Border>
                <Border x:Name="VoiceMessageRecordingBanner" Background="{StaticResource BgSidebar}" CornerRadius="4"
                        Padding="10,6" Margin="0,0,0,6" Visibility="Collapsed">
                    <TextBlock x:Name="VoiceMessageRecordingText" Text="Recording... 0:00" FontSize="12"
                               Foreground="#F23F42" FontWeight="Bold"/>
                </Border>
                <Grid AllowDrop="True" DragOver="MessageInputArea_DragOver" Drop="MessageInputArea_Drop">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="📎" Width="40" Height="40" Margin="0,0,8,0"
                            Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}"
                            BorderThickness="0" Click="AttachButton_Click" ToolTip="Attach a file"/>
                    <Button Grid.Column="1" x:Name="RecordVoiceMessageButton" Content="🎤" Width="40" Height="40" Margin="0,0,8,0"
                            Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}"
                            BorderThickness="0" Click="RecordVoiceMessageButton_Click" ToolTip="Record a voice message"/>
                    <TextBox Grid.Column="2" x:Name="MessageInput" Height="40" Padding="10,10" VerticalContentAlignment="Center"
                             Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}"
                             BorderThickness="0" KeyDown="MessageInput_KeyDown" TextChanged="MessageInput_TextChanged"
                             DataObject.Pasting="MessageInput_Pasting"/>
                    <Button Grid.Column="3" Content="Send" Width="80" Height="40" Margin="8,0,0,0"
                            Background="{StaticResource AccentBlurple}" Foreground="White"
                            BorderThickness="0" Click="SendButton_Click"/>
                </Grid>
            </StackPanel>
        </Grid>

        <!-- MEMBERS (server view only, see ShowServerSidebar/ShowMessagesSidebar/ShowFriendsSidebar) -->
        <Border x:Name="MembersPanel" Grid.Column="3" Background="{StaticResource BgSidebar}" Visibility="Collapsed">
            <DockPanel Margin="12">
                <TextBlock DockPanel.Dock="Top" Text="MEMBERS" FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource TextMuted}" Margin="4,4,0,8"/>
                <!-- ListBox instead of ItemsControl for built-in UI
                     virtualization (large servers) - ItemContainerStyle
                     strips ListBoxItem's default selection/hover chrome so
                     it's visually identical to the old ItemsControl rows,
                     same pattern as MessageList above. -->
                <ListBox x:Name="MemberList" Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Focusable" Value="False"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,4"
                                        ContextMenuOpening="MemberRow_ContextMenuOpening">
                                <StackPanel.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="{Binding RoleButtonLabel}" Tag="{Binding UserId}"
                                                  Click="MemberRoleButton_Click" Visibility="{Binding RoleButtonVisibility}"/>
                                        <MenuItem Header="Edit Permissions..." Tag="{Binding}" Click="MemberEditPermissionsButton_Click"
                                                  Visibility="{Binding EditPermissionsVisibility}"/>
                                        <MenuItem Header="Kick" Tag="{Binding UserId}" Click="MemberKickButton_Click"
                                                  Visibility="{Binding KickButtonVisibility}"/>
                                        <MenuItem Header="Ban..." Tag="{Binding UserId}" Click="MemberBanButton_Click"
                                                  Visibility="{Binding BanButtonVisibility}"/>
                                        <MenuItem Header="Purge Messages..." Tag="{Binding UserId}" Click="MemberPurgeButton_Click"
                                                  Visibility="{Binding PurgeButtonVisibility}"/>
                                    </ContextMenu>
                                </StackPanel.ContextMenu>
                                <local:AvatarView Size="28" DisplayName="{Binding Username}"
                                                   ImageUrl="{Binding AvatarUrl}" Margin="0,0,8,0"/>
                                <StackPanel VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Username}" Foreground="{StaticResource TextNormal}" FontSize="13"/>
                                        <Ellipse Width="8" Height="8" Margin="6,0,0,0" VerticalAlignment="Center"
                                                 Fill="#3BA55D" Visibility="{Binding OnlineDotVisibility}" ToolTip="Online"/>
                                        <Ellipse Width="8" Height="8" Margin="6,0,0,0" VerticalAlignment="Center"
                                                 Fill="#F0B232" Visibility="{Binding AwayDotVisibility}" ToolTip="Away"/>
                                        <Ellipse Width="8" Height="8" Margin="6,0,0,0" VerticalAlignment="Center"
                                                 Fill="#80848E" Visibility="{Binding OfflineDotVisibility}" ToolTip="Offline"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Role}" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                    <TextBlock Text="{Binding CustomStatus}" Foreground="{StaticResource TextMuted}" FontSize="11"
                                               TextTrimming="CharacterEllipsis" MaxWidth="140"
                                               Visibility="{Binding CustomStatusVisibility}"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- PAGE HOST - full replacement of the server rail through members
             column, hosting what used to be separate popup Windows
             (Settings, ban list, moderation log, invites, etc.) as inline
             pages instead - see NavigateTo/GoBack in MainWindow.xaml.cs. -->
        <Grid x:Name="PageHost" Grid.Column="0" Grid.ColumnSpan="4" Background="{StaticResource BgDark}" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="{StaticResource BgDark}" BorderBrush="{StaticResource BgDarker}" BorderThickness="0,0,0,1">
                <DockPanel Margin="16,12">
                    <Button DockPanel.Dock="Left" Content="←" FontSize="16" Width="36" Height="36" Margin="0,0,12,0"
                            Background="Transparent" Foreground="{StaticResource TextNormal}"
                            BorderThickness="0" Cursor="Hand" Click="PageHostBackButton_Click" ToolTip="Back"/>
                    <TextBlock x:Name="PageHostTitleText" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource TextNormal}"/>
                </DockPanel>
            </Border>
            <!-- No margin here - pages that have an edge-to-edge sidebar
                 (Settings) need to reach the window's left/bottom edges;
                 plain-content pages bring their own inner margin instead. -->
            <!-- TranslateTransform animated by GoBack's manual slide-out
                 (see MainWindow.xaml.cs) - NavigateTo's own entrance uses
                 WPF-UI's FadeInWithSlide transition instead, which manages
                 its own transform on this element directly. -->
            <ContentControl x:Name="PageHostContent" Grid.Row="1"
                             HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                <ContentControl.RenderTransform>
                    <TranslateTransform x:Name="PageHostContentTranslate" Y="0"/>
                </ContentControl.RenderTransform>
            </ContentControl>
        </Grid>

        <!-- MODAL OVERLAY - in-window replacement for ConfirmDialog/
             AlertDialog/TextInputDialog/CreateOrJoinDialog - see
             ConfirmAsync/AlertAsync/PromptAsync/CreateOrJoinAsync in
             MainWindow.xaml.cs. Scrim blocks input to everything beneath it. -->
        <Grid x:Name="ModalOverlay" Grid.Column="0" Grid.ColumnSpan="4" Background="#B3000000" Visibility="Collapsed">
            <!-- ScaleTransform animated by ShowModal/CompleteModal (see
                 MainWindow.xaml.cs) alongside the overlay's own WPF-UI
                 FadeIn transition, so the card scales in/out while the
                 backdrop fades - RenderTransformOrigin centers the scale
                 instead of growing from the top-left corner. -->
            <Border x:Name="ModalCard" Background="{StaticResource BgDark}" BorderBrush="{StaticResource BgDarker}" BorderThickness="1"
                    CornerRadius="6" Width="360" Padding="20" HorizontalAlignment="Center" VerticalAlignment="Center"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="ModalCardScale" ScaleX="1" ScaleY="1"/>
                </Border.RenderTransform>
                <StackPanel>
                    <TextBlock x:Name="ModalTitleText" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource TextNormal}" Margin="0,0,0,16"/>

                    <!-- Confirm/Alert/Prompt shape - message, optional input, dynamically-built buttons. -->
                    <StackPanel x:Name="ModalStandardPanel">
                        <TextBlock x:Name="ModalMessageText" TextWrapping="Wrap" FontSize="14"
                                   Foreground="{StaticResource TextNormal}" Margin="0,0,0,16"/>
                        <TextBox x:Name="ModalInputBox" Height="36" Padding="8" VerticalContentAlignment="Center"
                                 Margin="0,0,0,16" Visibility="Collapsed"
                                 Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}"
                                 BorderThickness="0" KeyDown="ModalInputBox_KeyDown"/>
                        <!-- Extra shape used only by PickOwnershipTransfersAsync - a
                             dynamically-built label+ComboBox pair per server, the same
                             content the old TransferOwnershipWindow built into its own
                             ServersPanel. Scrollable + capped so owning many servers
                             can't grow the card past the screen. -->
                        <ScrollViewer x:Name="ModalCustomContentScroll" MaxHeight="300" Margin="0,0,0,16" Visibility="Collapsed">
                            <StackPanel x:Name="ModalCustomContent"/>
                        </ScrollViewer>
                        <StackPanel x:Name="ModalButtonsPanel" Orientation="Horizontal" HorizontalAlignment="Right"/>
                    </StackPanel>

                    <!-- Create-or-join shape - two big fixed buttons, no message/input. -->
                    <StackPanel x:Name="ModalCreateOrJoinPanel" Visibility="Collapsed">
                        <Button x:Name="ModalCreateButton" Content="Create a Server" Height="48" Margin="0,0,0,12"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="16,0" FontWeight="Bold"
                                Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}" BorderThickness="0"
                                Cursor="Hand" Click="ModalCreateButton_Click"/>
                        <Button x:Name="ModalJoinButton" Content="Join with a Code" Height="48"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="16,0" FontWeight="Bold"
                                Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}" BorderThickness="0"
                                Cursor="Hand" Click="ModalJoinButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
