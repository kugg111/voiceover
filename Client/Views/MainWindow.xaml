<ui:FluentWindow x:Class="Voiceover.Client.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:Voiceover.Client.Views"
        xmlns:tb="clr-namespace:H.NotifyIcon;assembly=H.NotifyIcon.Wpf"
        Title="Voiceover" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDark}"
        Icon="/Assets/AppIcon.png"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        Closing="MainWindow_Closing"
        PreviewKeyDown="MainWindow_PreviewKeyDown">
    <ui:FluentWindow.Resources>
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <!-- Applied to every emoji Button (the picker grid + the "Add
             Reaction" trigger button) - see EmojiImageBehavior/EmojiImageCache
             for why plain text Content isn't used directly. Content is
             either a unicode glyph or a "custom:{id}" token (see
             CustomEmojiRegistry) - EmojiImageBehavior resolves either. -->
        <DataTemplate x:Key="EmojiButtonTemplate">
            <Image local:EmojiImageBehavior.Token="{Binding}"
                   Width="20" Height="20" Stretch="Uniform" SnapsToDevicePixels="True"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
        </DataTemplate>
        <!-- Compact round icon button used by the Discord-style voice control
             row (Mute/Deafen/Share/Leave) - a hover overlay is layered on top
             of (not swapped with) the button's own Background, so an active-
             state color (e.g. Deafen's red fill) stays visible on hover
             instead of being replaced by a neutral highlight. -->
        <Style x:Key="VoiceControlIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextNormal}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="18">
                            <Grid>
                                <Border x:Name="HoverOverlay" Background="#22FFFFFF" CornerRadius="18" Opacity="0"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverOverlay" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Non-visual - registers the tray icon with the OS on Loaded.
             Left in a closed-not-exited state by MainWindow_Closing (see
             TraySettingsStorage), so notifications keep firing while the
             window is hidden. -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        IconSource="/Assets/AppIcon.ico"
                        ToolTipText="Voiceover"
                        TrayLeftMouseDoubleClick="TrayIcon_DoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Open Voiceover" Click="TrayOpenMenuItem_Click"/>
                    <Separator/>
                    <MenuItem Header="Exit" Click="TrayExitMenuItem_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <ui:TitleBar Title="Voiceover" Grid.Row="0">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Assets/AppIcon.png"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="72"/>   <!-- server rail -->
            <ColumnDefinition Width="220"/>  <!-- channel sidebar -->
            <ColumnDefinition Width="*"/>    <!-- messages -->
            <ColumnDefinition Width="220"/>  <!-- members (server view only) -->
        </Grid.ColumnDefinitions>

        <!-- SERVER RAIL -->
        <Border Grid.Column="0" Background="{StaticResource BgDarker}">
            <DockPanel>
                <Button DockPanel.Dock="Bottom" Content="⎋" FontSize="18" Height="32" Width="48"
                        Margin="12,0,12,12" Background="Transparent" Foreground="{StaticResource TextMuted}"
                        BorderThickness="0" Click="LogOutButton_Click" ToolTip="Log out"/>
                <Border DockPanel.Dock="Bottom" Height="48" Width="48" Margin="12,0,12,4"
                        Background="Transparent" Cursor="Hand"
                        MouseLeftButtonUp="MyAvatarBorder_MouseLeftButtonUp" ToolTip="Settings">
                    <local:AvatarView x:Name="MyAvatarView" Size="44" IsHitTestVisible="False"/>
                </Border>
                <Button x:Name="AddServerButton" DockPanel.Dock="Bottom" Content="+" FontSize="20" Height="48" Width="48"
                        Margin="12,4,12,4" Background="{StaticResource BgSidebar}" Foreground="LightGreen"
                        BorderThickness="0" Click="AddServerButton_Click"/>
                <!-- First-run nudge for a brand-new user with zero servers -
                     shown/dismissed in code (UpdateOnboardingNudge), see
                     LoadServersAsync. -->
                <Popup x:Name="OnboardingNudgePopup" PlacementTarget="{Binding ElementName=AddServerButton}"
                       Placement="Right" HorizontalOffset="8" IsOpen="False" StaysOpen="True" AllowsTransparency="True"
                       Opened="OnboardingNudgePopup_Opened">
                    <Border x:Name="OnboardingNudgeCard" Background="{StaticResource AccentBlurple}" CornerRadius="6" Padding="10,8" MaxWidth="180"
                            Opacity="0" RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="OnboardingNudgeTranslate" X="-8"/>
                        </Border.RenderTransform>
                        <TextBlock Text="Create your first server here!" Foreground="White" FontSize="12" TextWrapping="Wrap"/>
                    </Border>
                </Popup>
                <Grid DockPanel.Dock="Top" Margin="12,12,12,4">
                    <Button x:Name="MessagesButton" Content="💬" FontSize="18" Height="48" Width="48"
                            Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}"
                            BorderThickness="0" Click="MessagesButton_Click" ToolTip="Messages"/>
                    <Border x:Name="MessagesUnreadBadge" MinWidth="16" Height="16" CornerRadius="8"
                            Background="{StaticResource AccentBlurple}" Padding="4,0"
                            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-4,0"
                            Visibility="Collapsed" IsHitTestVisible="False"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="MessagesUnreadBadgeScale"/>
                        </Border.RenderTransform>
                        <TextBlock x:Name="MessagesUnreadBadgeText" Text="0" FontSize="10" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
                <Button DockPanel.Dock="Top" x:Name="FriendsButton" Content="👥" FontSize="18" Height="48" Width="48"
                        Margin="12,0,12,8" Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}"
                        BorderThickness="0" Click="FriendsButton_Click" ToolTip="Friends"/>
                <Button DockPanel.Dock="Top" x:Name="DiscoverServersButton" Content="🧭" FontSize="18" Height="48" Width="48"
                        Margin="12,0,12,8" Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}"
                        BorderThickness="0" Click="DiscoverServersButton_Click" ToolTip="Discover Servers"/>
                <Border DockPanel.Dock="Top" Height="1" Background="{StaticResource BgSidebar}" Margin="16,0,16,8"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ServerList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Height="48" Width="48" Margin="12,8,12,0" Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="ServerButton_Click" Tag="{Binding Id}"
                                        ContextMenuOpening="ServerButton_ContextMenuOpening">
                                    <local:AvatarView Size="48" DisplayName="{Binding Name}" ImageUrl="{Binding IconUrl}"/>
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Add Channel" Tag="{Binding Id}" Click="AddChannelMenuItem_Click"/>
                                            <MenuItem Header="Invites" Tag="{Binding Id}" Click="InvitesMenuItem_Click"/>
                                            <MenuItem Header="Manage Emoji" Tag="{Binding Id}" Click="ManageEmojiMenuItem_Click"/>
                                            <MenuItem Header="Manage Categories" Tag="{Binding Id}" Click="ManageCategoriesMenuItem_Click"/>
                                            <MenuItem x:Name="ServerMuteMenuItem" Header="Mute Notifications" Tag="{Binding Id}" Click="ToggleServerMuteMenuItem_Click"/>
                                            <MenuItem Header="Leave Server" Tag="{Binding Id}" Click="LeaveServerMenuItem_Click"/>
                                            <MenuItem Header="Rename Server" Tag="{Binding Id}" Click="RenameServerMenuItem_Click"
                                                      Visibility="{Binding OwnerMenuItemVisibility}"/>
                                            <MenuItem Header="Discoverability..." Tag="{Binding Id}" Click="DiscoverabilityMenuItem_Click"
                                                      Visibility="{Binding OwnerMenuItemVisibility}"/>
                                            <MenuItem Header="Delete Server" Tag="{Binding Id}" Click="DeleteServerMenuItem_Click"
                                                      Visibility="{Binding OwnerMenuItemVisibility}"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- CHANNEL SIDEBAR -->
        <Border x:Name="ServerSidebarPanel" Grid.Column="1" Background="{StaticResource BgSidebar}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" x:Name="ServerNameText" Text="Select a server"
                           FontWeight="Bold" FontSize="15" Foreground="{StaticResource TextNormal}"
                           Padding="14,14,0,10"/>
                <!-- Compact Discord-style icon row for the mute/deafen/screen-share/
                     leave controls - a single Border (VoiceControlBar) whose
                     Visibility is toggled instead of each button's own, since
                     all four always show/hide together (see MainWindow.xaml.cs). -->
                <Border DockPanel.Dock="Bottom" x:Name="VoiceControlBar" Visibility="Collapsed"
                        Background="{StaticResource BgDarker}" Margin="8,0,8,8" CornerRadius="8" Padding="6">
                    <UniformGrid Columns="4" Rows="1">
                        <Button x:Name="MuteMicButton" Content="🎤" FontSize="15" ToolTip="Mute Mic"
                                Style="{StaticResource VoiceControlIconButtonStyle}"
                                Click="MuteMicButton_Click"/>
                        <Button x:Name="DeafenButton" Content="🎧" FontSize="15" ToolTip="Deafen"
                                Style="{StaticResource VoiceControlIconButtonStyle}"
                                Click="DeafenButton_Click"/>
                        <Button x:Name="ScreenShareButton" Content="🖥️" FontSize="15" ToolTip="Share Screen"
                                Style="{StaticResource VoiceControlIconButtonStyle}"
                                Click="ScreenShareButton_Click">
                            <Button.ContextMenu>
                                <!-- Resolution+framerate presets from the Phase 2 spike (see the plan) -
                                     480p30/720p60 are the committed tiers, Native/120fps is explicitly
                                     experimental/best-effort. -->
                                <ContextMenu x:Name="ScreenSharePresetMenu">
                                    <MenuItem Header="480p @ 30 fps (safe)" Click="ScreenShare480p30Fps_Click"/>
                                    <MenuItem Header="720p @ 60 fps (high)" Click="ScreenShare720p60Fps_Click"/>
                                    <MenuItem Header="Native @ 120 fps (experimental)" Click="ScreenShareNative120Fps_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Choose Different Source..." Click="ScreenShareChooseSource_Click"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                        <Button x:Name="LeaveVoiceButton" Content="📞" FontSize="14" ToolTip="Disconnect"
                                Style="{StaticResource VoiceControlIconButtonStyle}"
                                Foreground="White" Background="#F23F42"
                                Click="LeaveVoiceButton_Click"/>
                    </UniformGrid>
                </Border>

                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="TEXT CHANNELS" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}" Margin="14,6,0,4"/>
                    <ItemsControl x:Name="TextChannelList">
                        <!-- Groups by ChannelListItem.CategoryName (see MainWindow's
                             constructor, which sets ItemsSource to a grouped
                             CollectionView) - empty-string group (uncategorized)
                             renders no header at all via the converter below. -->
                        <ItemsControl.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="Bold"
                                                   Foreground="{StaticResource TextMuted}" Margin="14,10,0,4"
                                                   Visibility="{Binding Name, Converter={StaticResource StringToVisibilityConverter}}"/>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ItemsControl.GroupStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid AllowDrop="True"
                                      PreviewMouseLeftButtonDown="ChannelRow_PreviewMouseLeftButtonDown"
                                      PreviewMouseMove="ChannelRow_PreviewMouseMove"
                                      Drop="ChannelRow_Drop">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Content="{Binding DisplayName}" Tag="{Binding Id}"
                                            Click="ChannelButton_Click" HorizontalContentAlignment="Left"
                                            Background="Transparent" Foreground="{StaticResource TextMuted}"
                                            BorderThickness="0" Padding="14,6" Height="32"
                                            ContextMenuOpening="ChannelButton_ContextMenuOpening">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Set Slow Mode..." Tag="{Binding Id}" Click="SetSlowModeMenuItem_Click"/>
                                                <MenuItem x:Name="ChannelMuteMenuItem" Header="Mute Notifications" Tag="{Binding Id}" Click="ToggleChannelMuteMenuItem_Click"/>
                                                <MenuItem Header="Rename Channel" Tag="{Binding Id}" Click="RenameChannelMenuItem_Click"/>
                                                <!-- Populated dynamically each open (see
                                                     ChannelButton_ContextMenuOpening) - the set
                                                     of categories to offer isn't known at parse time. -->
                                                <MenuItem Header="Move to Category"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                    <Border Grid.Column="1" MinWidth="16" Height="16" CornerRadius="8" Margin="0,0,8,0"
                                            Background="{StaticResource AccentBlurple}" Padding="4,0"
                                            VerticalAlignment="Center" Visibility="{Binding UnreadBadgeVisibility}"
                                            RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform/>
                                        </Border.RenderTransform>
                                        <Border.Triggers>
                                            <!-- Bumps the badge on every count change (not just
                                                 appear/disappear) - NotifyOnTargetUpdated below makes the
                                                 TextBlock raise Binding.TargetUpdated on each new value,
                                                 which bubbles up to this EventTrigger. -->
                                            <EventTrigger RoutedEvent="Binding.TargetUpdated">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                         From="1.4" To="1.0" Duration="0:0:0.2"/>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                         From="1.4" To="1.0" Duration="0:0:0.2"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Border.Triggers>
                                        <TextBlock Text="{Binding UnreadCountDisplay, NotifyOnTargetUpdated=True}" FontSize="10" FontWeight="Bold"
                                                   Foreground="White" HorizontalAlignment="Center"/>
                                    </Border>
                                    <Button Grid.Column="2" Content="✕" Tag="{Binding Id}"
                                            Click="DeleteChannelButton_Click" ToolTip="Delete channel"
                                            Width="24" Height="24" Margin="0,0,8,0"
                                            Background="Transparent" Foreground="{StaticResource TextMuted}"
                                            BorderThickness="0"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="VOICE CHANNELS" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}" Margin="14,14,0,4"/>
                    <ItemsControl x:Name="VoiceChannelList">
                        <ItemsControl.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="Bold"
                                                   Foreground="{StaticResource TextMuted}" Margin="14,10,0,4"
                                                   Visibility="{Binding Name, Converter={StaticResource StringToVisibilityConverter}}"/>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ItemsControl.GroupStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <Grid AllowDrop="True"
                                          PreviewMouseLeftButtonDown="ChannelRow_PreviewMouseLeftButtonDown"
                                          PreviewMouseMove="ChannelRow_PreviewMouseMove"
                                          Drop="ChannelRow_Drop">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="{Binding DisplayName}" Tag="{Binding Id}"
                                                Click="VoiceChannelButton_Click" HorizontalContentAlignment="Left"
                                                Background="Transparent" Foreground="{StaticResource TextMuted}"
                                                BorderThickness="0" Padding="14,6" Height="32"
                                                ContextMenuOpening="VoiceChannelButton_ContextMenuOpening">
                                            <Button.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Rename Channel" Tag="{Binding Id}" Click="RenameChannelMenuItem_Click"/>
                                                    <MenuItem Header="Delete Channel" Tag="{Binding Id}" Click="DeleteChannelButton_Click"/>
                                                    <MenuItem Header="Move to Category"/>
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                        </Button>
                                        <!-- Opens this voice channel's text chat in the shared
                                             message pane (see MainWindow.VoiceChannelChatButton_Click)
                                             - a separate action from the row's own Click, which joins
                                             the voice audio instead. Messages work in any channel
                                             regardless of Type server-side; this is purely a client
                                             entry point into that existing pipeline. -->
                                        <Button Grid.Column="1" Content="💬" Tag="{Binding Id}"
                                                Click="VoiceChannelChatButton_Click" ToolTip="Text Chat"
                                                Width="26" Height="26" Padding="0" Margin="0,0,8,0"
                                                Background="Transparent" Foreground="{StaticResource TextMuted}"
                                                BorderThickness="0" Cursor="Hand"/>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding Members}" Margin="34,0,8,4" Focusable="False">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2"
                                                            Opacity="0" RenderTransformOrigin="0.5,0.5">
                                                    <!-- Entrance-only (WPF's ItemsControl removes containers
                                                         immediately on unbind, so there's no reliable hook for
                                                         an exit animation here without a heavier behavior) -
                                                         same fade+slide-up as the message list entrance below. -->
                                                    <StackPanel.RenderTransform>
                                                        <TranslateTransform Y="8"/>
                                                    </StackPanel.RenderTransform>
                                                    <StackPanel.Triggers>
                                                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     To="1" Duration="0:0:0.12"/>
                                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                                     To="0" Duration="0:0:0.12">
                                                                        <DoubleAnimation.EasingFunction>
                                                                            <QuadraticEase EasingMode="EaseOut"/>
                                                                        </DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </StackPanel.Triggers>
                                                    <Grid Width="20" Height="20" Margin="0,0,4,0">
                                                        <!-- Green speaking ring around the avatar, pulsing while
                                                             IsSpeaking - the same indicator the in-game overlay
                                                             uses, so both surfaces show "speaking" identically. -->
                                                        <Ellipse Width="20" Height="20" Stroke="#3BA55D" StrokeThickness="2"
                                                                 Fill="Transparent" Visibility="{Binding SpeakingDotVisibility}"
                                                                 RenderTransformOrigin="0.5,0.5">
                                                            <Ellipse.CacheMode>
                                                                <!-- Caches the ring as a GPU texture so the pulse is a cheap
                                                                     composition-thread scale of that texture, decoupled from
                                                                     MainWindow's busy UI thread and heavier per-frame
                                                                     compositing (which was stuttering the pulse here even
                                                                     though the identical animation is smooth in the
                                                                     lightweight overlay). RenderAtScale keeps the stroke
                                                                     crisp when scaled up. -->
                                                                <BitmapCache RenderAtScale="2"/>
                                                            </Ellipse.CacheMode>
                                                            <Ellipse.RenderTransform>
                                                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                            </Ellipse.RenderTransform>
                                                            <Ellipse.Style>
                                                                <Style TargetType="Ellipse">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSpeaking}" Value="True">
                                                                            <DataTrigger.EnterActions>
                                                                                <BeginStoryboard x:Name="SidebarSpeakingPulse">
                                                                                    <!-- No DesiredFrameRate here on purpose: setting it
                                                                                         forces the animation onto the UI thread, which
                                                                                         the busy MainWindow then starves (stutter). Left
                                                                                         as a composition-thread animation, smoothed via
                                                                                         the ring's BitmapCache above. -->
                                                                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                                                         To="1.2" Duration="0:0:0.5"/>
                                                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                                                         To="1.2" Duration="0:0:0.5"/>
                                                                                    </Storyboard>
                                                                                </BeginStoryboard>
                                                                            </DataTrigger.EnterActions>
                                                                            <DataTrigger.ExitActions>
                                                                                <StopStoryboard BeginStoryboardName="SidebarSpeakingPulse"/>
                                                                            </DataTrigger.ExitActions>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Ellipse.Style>
                                                        </Ellipse>
                                                        <local:AvatarView Size="16" DisplayName="{Binding Username}" ImageUrl="{Binding AvatarUrl}"/>
                                                    </Grid>
                                                    <TextBlock Text="🔇" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"
                                                               Visibility="{Binding MutedIconVisibility}" ToolTip="Muted"/>
                                                    <TextBlock Text="🎧" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"
                                                               Visibility="{Binding DeafenedIconVisibility}" ToolTip="Deafened"/>
                                                    <Border Cursor="Hand" Margin="0,0,4,0" VerticalAlignment="Center"
                                                            Visibility="{Binding ScreenSharingIconVisibility}"
                                                            ToolTip="Sharing screen - click to view" Tag="{Binding UserId}"
                                                            MouseLeftButtonUp="ScreenShareIcon_MouseLeftButtonUp">
                                                        <Viewbox Width="12" Height="12">
                                                            <Canvas Width="24" Height="24">
                                                                <Rectangle Canvas.Left="2" Canvas.Top="3" Width="20" Height="14" RadiusX="2" RadiusY="2" Fill="{StaticResource AccentBlurple}"/>
                                                                <Rectangle Canvas.Left="9" Canvas.Top="18" Width="6" Height="3" Fill="{StaticResource AccentBlurple}"/>
                                                                <Rectangle Canvas.Left="6" Canvas.Top="20" Width="12" Height="2" RadiusX="1" RadiusY="1" Fill="{StaticResource AccentBlurple}"/>
                                                            </Canvas>
                                                        </Viewbox>
                                                    </Border>
                                                    <TextBlock Text="{Binding Username}" FontSize="12" VerticalAlignment="Center"
                                                               Foreground="{Binding UsernameForeground}"
                                                               ToolTip="{Binding JoiningTooltip}"/>
                                                    <StackPanel.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="{Binding Username}" IsEnabled="False" FontWeight="Bold"
                                                                      Visibility="{Binding VolumeSliderVisibility}"/>
                                                            <MenuItem StaysOpenOnClick="True" Visibility="{Binding VolumeSliderVisibility}">
                                                                <MenuItem.Header>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <Slider Width="150" Minimum="0" Maximum="200"
                                                                                Value="{Binding Volume, Mode=TwoWay}"
                                                                                ValueChanged="VoiceMemberVolumeSlider_ValueChanged"/>
                                                                        <TextBlock Text="{Binding VolumeDisplay}" Width="38" Margin="6,0,0,0"
                                                                                   VerticalAlignment="Center" Foreground="{StaticResource TextMuted}"/>
                                                                    </StackPanel>
                                                                </MenuItem.Header>
                                                            </MenuItem>
                                                            <MenuItem Header="This is you" IsEnabled="False"
                                                                      Visibility="{Binding SelfMenuItemVisibility}"/>
                                                        </ContextMenu>
                                                    </StackPanel.ContextMenu>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- MESSAGES SIDEBAR (conversation list) -->
        <Border x:Name="MessagesSidebarPanel" Grid.Column="1" Background="{StaticResource BgSidebar}" Visibility="Collapsed">
            <DockPanel>
                <Grid DockPanel.Dock="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Direct Messages"
                               FontWeight="Bold" FontSize="15" Foreground="{StaticResource TextNormal}"
                               Padding="14,14,0,10" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="📞" Width="26" Height="26" Padding="0" Margin="0,8,10,0"
                            Click="RecentCallsButton_Click" ToolTip="Recent Calls"
                            Background="Transparent" Foreground="{StaticResource TextNormal}"
                            BorderThickness="0" FontSize="12" Cursor="Hand"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                </Grid>
                <TextBox DockPanel.Dock="Top" x:Name="DmSearchBox" Height="34" Margin="10,0,10,8" Padding="8,6"
                         Background="{StaticResource BgDarker}" Foreground="{StaticResource TextNormal}"
                         BorderThickness="0" TextChanged="DmSearchBox_TextChanged"/>
                <ItemsControl DockPanel.Dock="Top" x:Name="DmSearchResultsList">
                    <ItemsControl.ItemTemplate>
