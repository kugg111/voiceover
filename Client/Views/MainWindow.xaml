<ui:FluentWindow x:Class="Voiceover.Client.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:Voiceover.Client.Views"
        Title="Voiceover" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDark}"
        Icon="/Assets/AppIcon.png"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Voiceover" Grid.Row="0">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Assets/AppIcon.png"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="72"/>   <!-- server rail -->
            <ColumnDefinition Width="220"/>  <!-- channel sidebar -->
            <ColumnDefinition Width="*"/>    <!-- messages -->
            <ColumnDefinition Width="220"/>  <!-- members (server view only) -->
        </Grid.ColumnDefinitions>

        <!-- SERVER RAIL -->
        <Border Grid.Column="0" Background="{StaticResource BgDarker}">
            <DockPanel>
                <Button DockPanel.Dock="Bottom" Content="⎋" FontSize="18" Height="32" Width="48"
                        Margin="12,0,12,12" Background="Transparent" Foreground="{StaticResource TextMuted}"
                        BorderThickness="0" Click="LogOutButton_Click" ToolTip="Log out"/>
                <Border DockPanel.Dock="Bottom" Height="48" Width="48" Margin="12,0,12,4"
                        Background="Transparent" Cursor="Hand"
                        MouseLeftButtonUp="MyAvatarBorder_MouseLeftButtonUp" ToolTip="Settings">
                    <local:AvatarView x:Name="MyAvatarView" Size="44" IsHitTestVisible="False"/>
                </Border>
                <Button DockPanel.Dock="Bottom" Content="+" FontSize="20" Height="48" Width="48"
                        Margin="12,4,12,4" Background="{StaticResource BgSidebar}" Foreground="LightGreen"
                        BorderThickness="0" Click="AddServerButton_Click"/>
                <Grid DockPanel.Dock="Top" Margin="12,12,12,4">
                    <Button x:Name="MessagesButton" Content="💬" FontSize="18" Height="48" Width="48"
                            Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}"
                            BorderThickness="0" Click="MessagesButton_Click" ToolTip="Messages"/>
                    <Border x:Name="MessagesUnreadBadge" MinWidth="16" Height="16" CornerRadius="8"
                            Background="{StaticResource AccentBlurple}" Padding="4,0"
                            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-4,0"
                            Visibility="Collapsed" IsHitTestVisible="False">
                        <TextBlock x:Name="MessagesUnreadBadgeText" Text="0" FontSize="10" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
                <Button DockPanel.Dock="Top" x:Name="FriendsButton" Content="👥" FontSize="18" Height="48" Width="48"
                        Margin="12,0,12,8" Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}"
                        BorderThickness="0" Click="FriendsButton_Click" ToolTip="Friends"/>
                <Border DockPanel.Dock="Top" Height="1" Background="{StaticResource BgSidebar}" Margin="16,0,16,8"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ServerList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Height="48" Width="48" Margin="12,8,12,0" Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="ServerButton_Click" Tag="{Binding Id}">
                                    <local:AvatarView Size="48" DisplayName="{Binding Name}" ImageUrl="{Binding IconUrl}"/>
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Add Channel" Tag="{Binding Id}" Click="AddChannelMenuItem_Click"/>
                                            <MenuItem Header="Invites" Tag="{Binding Id}" Click="InvitesMenuItem_Click"/>
                                            <MenuItem Header="Leave Server" Tag="{Binding Id}" Click="LeaveServerMenuItem_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- CHANNEL SIDEBAR -->
        <Border x:Name="ServerSidebarPanel" Grid.Column="1" Background="{StaticResource BgSidebar}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" x:Name="ServerNameText" Text="Select a server"
                           FontWeight="Bold" FontSize="15" Foreground="{StaticResource TextNormal}"
                           Padding="14,14,0,10"/>
                <Button DockPanel.Dock="Bottom" x:Name="LeaveVoiceButton" Content="Leave Voice" Margin="10,0,10,10"
                        Background="Transparent" Foreground="#F23F42"
                        BorderThickness="0" HorizontalContentAlignment="Left" Visibility="Collapsed"
                        Click="LeaveVoiceButton_Click"/>
                <Button DockPanel.Dock="Bottom" x:Name="DeafenButton" Content="🎧 Deafen" Margin="10,0,10,0"
                        Background="Transparent" Foreground="{StaticResource TextMuted}"
                        BorderThickness="0" HorizontalContentAlignment="Left" Visibility="Collapsed"
                        Click="DeafenButton_Click"/>
                <Button DockPanel.Dock="Bottom" x:Name="MuteMicButton" Content="🎤 Mute Mic" Margin="10,0,10,0"
                        Background="Transparent" Foreground="{StaticResource TextMuted}"
                        BorderThickness="0" HorizontalContentAlignment="Left" Visibility="Collapsed"
                        Click="MuteMicButton_Click"/>
                <Button DockPanel.Dock="Bottom" x:Name="ScreenShareButton" Content="🖥️ Share Screen" Margin="10,0,10,0"
                        Background="Transparent" Foreground="{StaticResource TextMuted}"
                        BorderThickness="0" HorizontalContentAlignment="Left" Visibility="Collapsed"
                        Click="ScreenShareButton_Click">
                    <Button.ContextMenu>
                        <!-- Frame-rate presets from the Phase 2 spike (see the plan) - 30/60 are
                             the committed tiers, 120 is explicitly experimental/best-effort. -->
                        <ContextMenu x:Name="ScreenSharePresetMenu">
                            <MenuItem Header="30 fps (safe)" Click="ScreenShare30Fps_Click"/>
                            <MenuItem Header="60 fps (high)" Click="ScreenShare60Fps_Click"/>
                            <MenuItem Header="120 fps (experimental)" Click="ScreenShare120Fps_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="TEXT CHANNELS" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}" Margin="14,6,0,4"/>
                    <ItemsControl x:Name="TextChannelList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Content="{Binding DisplayName}" Tag="{Binding Id}"
                                            Click="ChannelButton_Click" HorizontalContentAlignment="Left"
                                            Background="Transparent" Foreground="{StaticResource TextMuted}"
                                            BorderThickness="0" Padding="14,6" Height="32"/>
                                    <Border Grid.Column="1" MinWidth="16" Height="16" CornerRadius="8" Margin="0,0,8,0"
                                            Background="{StaticResource AccentBlurple}" Padding="4,0"
                                            VerticalAlignment="Center" Visibility="{Binding UnreadBadgeVisibility}">
                                        <TextBlock Text="{Binding UnreadCountDisplay}" FontSize="10" FontWeight="Bold"
                                                   Foreground="White" HorizontalAlignment="Center"/>
                                    </Border>
                                    <Button Grid.Column="2" Content="✕" Tag="{Binding Id}"
                                            Click="DeleteChannelButton_Click" ToolTip="Delete channel"
                                            Width="24" Height="24" Margin="0,0,8,0"
                                            Background="Transparent" Foreground="{StaticResource TextMuted}"
                                            BorderThickness="0"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="VOICE CHANNELS" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}" Margin="14,14,0,4"/>
                    <ItemsControl x:Name="VoiceChannelList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Content="{Binding DisplayName}" Tag="{Binding Id}"
                                                Click="VoiceChannelButton_Click" HorizontalContentAlignment="Left"
                                                Background="Transparent" Foreground="{StaticResource TextMuted}"
                                                BorderThickness="0" Padding="14,6" Height="32"/>
                                        <Button Grid.Column="1" Content="✕" Tag="{Binding Id}"
                                                Click="DeleteChannelButton_Click" ToolTip="Delete channel"
                                                Width="24" Height="24" Margin="0,0,8,0"
                                                Background="Transparent" Foreground="{StaticResource TextMuted}"
                                                BorderThickness="0"/>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding Members}" Margin="34,0,8,4" Focusable="False">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                                    <local:AvatarView Size="16" DisplayName="{Binding Username}" ImageUrl="{Binding AvatarUrl}" Margin="0,0,4,0"/>
                                                    <TextBlock Text="🔇" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"
                                                               Visibility="{Binding MutedIconVisibility}" ToolTip="Muted"/>
                                                    <TextBlock Text="🎧" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"
                                                               Visibility="{Binding DeafenedIconVisibility}" ToolTip="Deafened"/>
                                                    <TextBlock Text="🖥️" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"
                                                               Visibility="{Binding ScreenSharingIconVisibility}" ToolTip="Sharing screen"/>
                                                    <TextBlock Text="{Binding Username}" FontSize="12" VerticalAlignment="Center"
                                                               Foreground="{Binding UsernameForeground}"
                                                               ToolTip="{Binding JoiningTooltip}"/>
                                                    <Ellipse Width="8" Height="8" Margin="6,0,0,0" VerticalAlignment="Center"
                                                             Fill="{StaticResource AccentBlurple}"
                                                             Visibility="{Binding SpeakingDotVisibility}"/>
                                                    <StackPanel.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="{Binding Username}" IsEnabled="False" FontWeight="Bold"
                                                                      Visibility="{Binding VolumeSliderVisibility}"/>
                                                            <MenuItem StaysOpenOnClick="True" Visibility="{Binding VolumeSliderVisibility}">
                                                                <MenuItem.Header>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <Slider Width="150" Minimum="0" Maximum="200"
                                                                                Value="{Binding Volume, Mode=TwoWay}"
                                                                                ValueChanged="VoiceMemberVolumeSlider_ValueChanged"/>
                                                                        <TextBlock Text="{Binding VolumeDisplay}" Width="38" Margin="6,0,0,0"
                                                                                   VerticalAlignment="Center" Foreground="{StaticResource TextMuted}"/>
                                                                    </StackPanel>
                                                                </MenuItem.Header>
                                                            </MenuItem>
                                                            <MenuItem Header="This is you" IsEnabled="False"
                                                                      Visibility="{Binding SelfMenuItemVisibility}"/>
                                                        </ContextMenu>
                                                    </StackPanel.ContextMenu>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- MESSAGES SIDEBAR (conversation list) -->
        <Border x:Name="MessagesSidebarPanel" Grid.Column="1" Background="{StaticResource BgSidebar}" Visibility="Collapsed">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Direct Messages"
                           FontWeight="Bold" FontSize="15" Foreground="{StaticResource TextNormal}"
                           Padding="14,14,0,10"/>
                <TextBox DockPanel.Dock="Top" x:Name="DmSearchBox" Height="34" Margin="10,0,10,8" Padding="8,6"
                         Background="{StaticResource BgDarker}" Foreground="{StaticResource TextNormal}"
                         BorderThickness="0" TextChanged="DmSearchBox_TextChanged"/>
                <ItemsControl DockPanel.Dock="Top" x:Name="DmSearchResultsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Tag="{Binding Id}" Click="DmSearchResult_Click"
                                    HorizontalContentAlignment="Left" Background="Transparent"
                                    Foreground="{StaticResource TextNormal}" BorderThickness="0" Padding="14,8">
                                <StackPanel Orientation="Horizontal">
                                    <local:AvatarView Size="24" DisplayName="{Binding Username}" ImageUrl="{Binding AvatarUrl}" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Username}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ScrollViewer>
                    <ItemsControl x:Name="DmConversationList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Click="DmConversation_Click" Tag="{Binding OtherUserId}"
                                        HorizontalContentAlignment="Stretch" Background="Transparent"
                                        BorderThickness="0" Padding="14,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <local:AvatarView Grid.Column="0" Size="32" DisplayName="{Binding OtherUsername}"
                                                           ImageUrl="{Binding OtherUserAvatarUrl}" Margin="0,0,8,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding OtherUsername}" FontWeight="Bold"
                                                       Foreground="{StaticResource TextNormal}"/>
                                            <TextBlock Text="{Binding PreviewDisplay}" FontSize="11"
                                                       Foreground="{StaticResource TextMuted}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Border Grid.Column="2" MinWidth="16" Height="16" CornerRadius="8" Margin="8,0,0,0"
                                                Background="{StaticResource AccentBlurple}" Padding="4,0"
                                                VerticalAlignment="Center" Visibility="{Binding UnreadBadgeVisibility}">
                                            <TextBlock Text="{Binding UnreadCountDisplay}" FontSize="10" FontWeight="Bold"
                                                       Foreground="White" HorizontalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- FRIENDS SIDEBAR -->
        <Border x:Name="FriendsSidebarPanel" Grid.Column="1" Background="{StaticResource BgSidebar}" Visibility="Collapsed">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Friends"
                           FontWeight="Bold" FontSize="15" Foreground="{StaticResource TextNormal}"
                           Padding="14,14,0,10"/>
                <TextBox DockPanel.Dock="Top" x:Name="FriendSearchBox" Height="34" Margin="10,0,10,8" Padding="8,6"
                         Background="{StaticResource BgDarker}" Foreground="{StaticResource TextNormal}"
                         BorderThickness="0" TextChanged="FriendSearchBox_TextChanged"/>
                <ItemsControl DockPanel.Dock="Top" x:Name="FriendSearchResultsList" Margin="0,0,0,4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <local:AvatarView Grid.Column="0" Size="24" DisplayName="{Binding Username}"
                                                   ImageUrl="{Binding AvatarUrl}" Margin="14,0,8,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Username}" Foreground="{StaticResource TextNormal}"
                                           VerticalAlignment="Center" Padding="0,8"/>
                                <Button Grid.Column="2" Content="Add" Tag="{Binding Id}" Click="AddFriendButton_Click"
                                        Background="{StaticResource AccentBlurple}" Foreground="White"
                                        BorderThickness="0" Padding="8,2" Margin="0,0,10,0"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ScrollViewer>
                    <StackPanel>
                        <TextBlock Text="PENDING REQUESTS" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextMuted}" Margin="14,10,0,4"/>
                        <ItemsControl x:Name="FriendRequestList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <local:AvatarView Grid.Column="0" Size="24" DisplayName="{Binding Username}"
                                                           ImageUrl="{Binding AvatarUrl}" Margin="14,0,8,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Username}" Foreground="{StaticResource TextNormal}"
                                                   VerticalAlignment="Center" Padding="0,6"/>
                                        <Button Grid.Column="2" Content="Accept" Tag="{Binding Id}"
                                                Click="FriendRequestAcceptButton_Click" Visibility="{Binding AcceptButtonVisibility}"
                                                Background="{StaticResource AccentBlurple}" Foreground="White"
                                                BorderThickness="0" Padding="8,2" Margin="0,0,4,0"/>
                                        <Button Grid.Column="3" Content="{Binding SecondaryActionLabel}" Tag="{Binding Id}"
                                                Click="FriendRequestRemoveButton_Click"
                                                Background="{StaticResource BgDarker}" Foreground="{StaticResource TextMuted}"
                                                BorderThickness="0" Padding="8,2" Margin="0,0,10,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="ALL FRIENDS" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextMuted}" Margin="14,14,0,4"/>
                        <ItemsControl x:Name="FriendList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Tag="{Binding UserId}" Click="FriendListItem_Click"
                                                HorizontalContentAlignment="Left" Background="Transparent"
                                                Foreground="{StaticResource TextNormal}" BorderThickness="0" Padding="14,8">
                                            <StackPanel Orientation="Horizontal">
                                                <local:AvatarView Size="24" DisplayName="{Binding Username}" ImageUrl="{Binding AvatarUrl}" Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding Username}" VerticalAlignment="Center"/>
                                                <Ellipse Width="8" Height="8" Margin="6,0,0,0" VerticalAlignment="Center"
                                                         Fill="#3BA55D" Visibility="{Binding OnlineDotVisibility}" ToolTip="Online"/>
                                                <Ellipse Width="8" Height="8" Margin="6,0,0,0" VerticalAlignment="Center"
                                                         Fill="#F0B232" Visibility="{Binding AwayDotVisibility}" ToolTip="Away"/>
                                                <Ellipse Width="8" Height="8" Margin="6,0,0,0" VerticalAlignment="Center"
                                                         Fill="#80848E" Visibility="{Binding OfflineDotVisibility}" ToolTip="Offline"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="1" Tag="{Binding UserId}" Click="CallFriendButton_Click"
                                                Background="Transparent" Foreground="{StaticResource TextMuted}"
                                                BorderThickness="0" Padding="8" Cursor="Hand" ToolTip="Call"
                                                VerticalAlignment="Center" Margin="0,0,8,0">
                                            <TextBlock Text="📞" FontSize="14"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- MESSAGE AREA -->
        <Grid Grid.Column="2" Background="{StaticResource BgDark}">
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource BgDark}" BorderBrush="{StaticResource BgDarker}" BorderThickness="0,0,0,1">
                <DockPanel>
                    <TextBlock x:Name="ConnectionStatusText" DockPanel.Dock="Right" Text=""
                               Foreground="#F0B232" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button x:Name="DmCallButton" DockPanel.Dock="Right" Content="📞" ToolTip="Call" Margin="0,0,12,0"
                            Background="Transparent" Foreground="{StaticResource TextMuted}"
                            BorderThickness="0" Cursor="Hand" Visibility="Collapsed"
                            Click="DmCallButton_Click"/>
                    <TextBlock x:Name="ChannelNameText" Text="# select-a-channel"
                               Foreground="{StaticResource TextNormal}" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="16,0,0,0"/>
                </DockPanel>
            </Border>

            <ScrollViewer Grid.Row="1" x:Name="MessageScroll" Padding="16,8">
                <ItemsControl x:Name="MessageList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid x:Name="MessageRow" Margin="0,6,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Edit Message" Tag="{Binding Id}" Click="EditMessageMenuItem_Click"
                                                  Visibility="{Binding EditMenuVisibility}"/>
                                        <MenuItem Header="Delete Message" Tag="{Binding Id}" Click="DeleteMessageMenuItem_Click"
                                                  Visibility="{Binding DeleteMenuVisibility}"/>
                                    </ContextMenu>
                                </Grid.ContextMenu>
                                <local:AvatarView Grid.Column="0" Size="36" DisplayName="{Binding AuthorUsername}"
                                                   ImageUrl="{Binding AuthorAvatarUrl}" Margin="0,2,10,0" VerticalAlignment="Top"/>
                                <!-- Quicker alternative to the right-click context menu above - only
                                     shown while hovering this row, same as Discord's own hover actions,
                                     so the row doesn't stay visually busy with icons all the time. -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top" Margin="8,2,0,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Grid}}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Button Content="✏️" Tag="{Binding Id}" Click="EditMessageMenuItem_Click"
                                            Visibility="{Binding EditMenuVisibility}" ToolTip="Edit"
                                            Width="26" Height="26" Padding="0" FontSize="12" Margin="0,0,4,0"
                                            Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}"
                                            BorderThickness="0" Cursor="Hand"/>
                                    <Button Content="🗑️" Tag="{Binding Id}" Click="DeleteMessageMenuItem_Click"
                                            Visibility="{Binding DeleteMenuVisibility}" ToolTip="Delete"
                                            Width="26" Height="26" Padding="0" FontSize="12"
                                            Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}"
                                            BorderThickness="0" Cursor="Hand"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding AuthorUsername}" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBlurple}" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding TimeDisplay}" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                        <TextBlock Text="(edited)" FontSize="11" Margin="4,0,0,0"
                                                   Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"
                                                   Visibility="{Binding EditedTagVisibility}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Content}" Foreground="{StaticResource TextNormal}"
                                               TextWrapping="Wrap" Visibility="{Binding ContentVisibility}"/>
                                    <StackPanel Visibility="{Binding EditBoxVisibility}" Margin="0,2,0,0">
                                        <TextBox Text="{Binding EditingContent, UpdateSourceTrigger=PropertyChanged}"
                                                 AcceptsReturn="False" TextWrapping="Wrap"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Button Content="Save" Tag="{Binding Id}" Click="SaveMessageEditButton_Click"
                                                    Padding="10,2" Margin="0,0,6,0"/>
                                            <Button Content="Cancel" Tag="{Binding Id}" Click="CancelMessageEditButton_Click"
                                                    Padding="10,2" Background="Transparent"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Text="{Binding AttachmentDisplay}" Foreground="{StaticResource AccentBlurple}"
                                               TextDecorations="Underline" Cursor="Hand"
                                               Visibility="{Binding AttachmentVisibility}"
                                               MouseLeftButtonUp="AttachmentLink_MouseLeftButtonUp"
                                               Tag="{Binding AttachmentUrl}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Grid Grid.Row="2" Margin="16,0,16,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="📎" Width="40" Height="40" Margin="0,0,8,0"
                        Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}"
                        BorderThickness="0" Click="AttachButton_Click" ToolTip="Attach a file"/>
                <TextBox Grid.Column="1" x:Name="MessageInput" Height="40" Padding="10,10" VerticalContentAlignment="Center"
                         Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}"
                         BorderThickness="0" KeyDown="MessageInput_KeyDown" TextChanged="MessageInput_TextChanged"/>
                <Button Grid.Column="2" Content="Send" Width="80" Height="40" Margin="8,0,0,0"
                        Background="{StaticResource AccentBlurple}" Foreground="White"
                        BorderThickness="0" Click="SendButton_Click"/>
            </Grid>
        </Grid>

        <!-- MEMBERS (server view only, see ShowServerSidebar/ShowMessagesSidebar/ShowFriendsSidebar) -->
        <Border x:Name="MembersPanel" Grid.Column="3" Background="{StaticResource BgSidebar}" Visibility="Collapsed">
            <DockPanel Margin="12">
                <TextBlock DockPanel.Dock="Top" Text="MEMBERS" FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource TextMuted}" Margin="4,4,0,8"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="MemberList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,4"
                                            ContextMenuOpening="MemberRow_ContextMenuOpening">
                                    <StackPanel.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="{Binding RoleButtonLabel}" Tag="{Binding UserId}"
                                                      Click="MemberRoleButton_Click" Visibility="{Binding RoleButtonVisibility}"/>
                                            <MenuItem Header="Kick" Tag="{Binding UserId}" Click="MemberKickButton_Click"
                                                      Visibility="{Binding KickButtonVisibility}"/>
                                        </ContextMenu>
                                    </StackPanel.ContextMenu>
                                    <local:AvatarView Size="28" DisplayName="{Binding Username}"
                                                       ImageUrl="{Binding AvatarUrl}" Margin="0,0,8,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Username}" Foreground="{StaticResource TextNormal}" FontSize="13"/>
                                            <Ellipse Width="8" Height="8" Margin="6,0,0,0" VerticalAlignment="Center"
                                                     Fill="#3BA55D" Visibility="{Binding OnlineDotVisibility}" ToolTip="Online"/>
                                            <Ellipse Width="8" Height="8" Margin="6,0,0,0" VerticalAlignment="Center"
                                                     Fill="#F0B232" Visibility="{Binding AwayDotVisibility}" ToolTip="Away"/>
                                            <Ellipse Width="8" Height="8" Margin="6,0,0,0" VerticalAlignment="Center"
                                                     Fill="#80848E" Visibility="{Binding OfflineDotVisibility}" ToolTip="Offline"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Role}" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
