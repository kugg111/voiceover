<Window x:Class="Voiceover.Client.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Voiceover.Client.Views"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        IsHitTestVisible="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Left="0" Top="0">
    <!-- Semi-transparent card, deliberately distinct from the in-app sidebar
         look so it reads as an overlay. Colors are hardcoded (not the app
         brushes) because the overlay wants its own translucent palette. -->
    <!-- OverlayCard.Background is overwritten from OverlaySettingsStorage at
         runtime (see OverlayWindow.SetBackgroundOpacity); this literal is just
         the default-transparency starting value. No border and no header - just
         the member rows on the translucent backdrop. -->
    <Border x:Name="OverlayCard" Background="#261E1F22" CornerRadius="8" Padding="10,8" MinWidth="180">
        <StackPanel>
            <ItemsControl x:Name="MemberList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Grid Width="24" Height="24" Margin="0,0,8,0">
                                <!-- Blurple speaking ring (the app's AccentBlurple #5865F2),
                                     shown + pulsing only while IsSpeaking. -->
                                <Ellipse Width="24" Height="24" Stroke="#5865F2" StrokeThickness="2"
                                         Fill="Transparent" Visibility="{Binding SpeakingDotVisibility}"
                                         RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform>
                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                    </Ellipse.RenderTransform>
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSpeaking}" Value="True">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard x:Name="OverlaySpeakingPulse">
                                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                                 To="1.25" Duration="0:0:0.5"/>
                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                                 To="1.25" Duration="0:0:0.5"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <StopStoryboard BeginStoryboardName="OverlaySpeakingPulse"/>
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <local:AvatarView Size="20" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  DisplayName="{Binding Username}" ImageUrl="{Binding AvatarUrl}"/>
                            </Grid>
                            <TextBlock Text="{Binding Username}" Foreground="White" FontSize="12"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="🔇" FontSize="10" VerticalAlignment="Center" Margin="6,0,0,0"
                                       Visibility="{Binding MutedIconVisibility}" ToolTip="Muted"/>
                            <TextBlock Text="🎧" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"
                                       Visibility="{Binding DeafenedIconVisibility}" ToolTip="Deafened"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</Window>
