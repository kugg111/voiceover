<ui:FluentWindow x:Class="Voiceover.Client.Views.UpdateGateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Voiceover" Height="320" Width="380"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDark}"
        ResizeMode="NoResize"
        Icon="/Assets/AppIcon.png"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Voiceover" Grid.Row="0" ShowMaximize="False" ShowMinimize="False"/>

        <Grid Grid.Row="1" Margin="32">
        <StackPanel VerticalAlignment="Center">
            <Image Source="/Assets/AppIcon.png" Width="64" Height="64" Margin="0,0,0,16"/>

            <ProgressBar x:Name="CheckingSpinner" IsIndeterminate="True" Height="4"
                         Background="{StaticResource BgDarker}" Foreground="{StaticResource AccentBlurple}"
                         BorderThickness="0" Margin="0,0,0,14"/>

            <TextBlock x:Name="TitleText" Text="Checking for updates…" FontSize="16" FontWeight="Bold"
                       Foreground="{StaticResource TextNormal}" HorizontalAlignment="Center"
                       Margin="0,0,0,6" TextWrapping="Wrap" TextAlignment="Center"/>
            <TextBlock x:Name="DetailText" Text="" FontSize="12"
                       Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"
                       Margin="0,0,0,4" TextWrapping="Wrap" TextAlignment="Center"/>
            <TextBlock x:Name="MandatoryText" Text="This update is required to continue." FontSize="12"
                       Foreground="{StaticResource DangerRed}" HorizontalAlignment="Center"
                       Margin="0,0,0,4" TextWrapping="Wrap" TextAlignment="Center"
                       Visibility="Collapsed"/>

            <ProgressBar x:Name="DownloadProgressBar" Height="4" Minimum="0" Maximum="100"
                         Background="{StaticResource BgDarker}" Foreground="{StaticResource AccentBlurple}"
                         BorderThickness="0" Margin="0,10,0,0" Visibility="Collapsed"/>

            <StackPanel x:Name="ActionButtons" Orientation="Horizontal" HorizontalAlignment="Center"
                        Margin="0,18,0,0" Visibility="Collapsed">
                <Button x:Name="SkipButton" Content="Skip for now" Height="36" Width="120"
                        HorizontalContentAlignment="Center"
                        Background="Transparent" Foreground="{StaticResource TextMuted}"
                        BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"
                        Click="SkipButton_Click"/>
                <Button x:Name="UpdateButton" Content="Update Now" Height="36" Width="140"
                        HorizontalContentAlignment="Center"
                        Background="{StaticResource AccentBlurple}" Foreground="White"
                        BorderThickness="0" FontWeight="Bold" Cursor="Hand"
                        Click="UpdateButton_Click"/>
            </StackPanel>
        </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
