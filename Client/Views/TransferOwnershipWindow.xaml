<ui:FluentWindow x:Class="Voiceover.Client.Views.TransferOwnershipWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Transfer Ownership" Width="420" SizeToContent="Height" MinHeight="0" MaxHeight="600"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgDark}"
        ResizeMode="NoResize"
        Icon="/Assets/AppIcon.png"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Transfer Ownership" Grid.Row="0" ShowMaximize="False"/>

        <StackPanel Grid.Row="1" Margin="20">
            <TextBlock Text="You own servers with other members - pick who takes over each one before your account is deleted."
                       TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,0,0,16"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="360">
                <StackPanel x:Name="ServersPanel"/>
            </ScrollViewer>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="CancelButton" Content="Cancel" Height="36" Width="90" Margin="0,0,8,0"
                        Background="Transparent" Foreground="{StaticResource TextNormal}"
                        BorderThickness="0" Cursor="Hand" Click="CancelButton_Click"/>
                <Button x:Name="ContinueButton" Content="Continue" Height="36" Width="100"
                        Background="{StaticResource AccentBlurple}" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Click="ContinueButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
