<ui:FluentWindow x:Class="Voiceover.Client.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Settings" Height="360" Width="380"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgDark}"
        ResizeMode="NoResize"
        Icon="/Assets/AppIcon.png"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Settings" Grid.Row="0" ShowMaximize="False"/>

        <StackPanel Grid.Row="1" Margin="20">
            <Button x:Name="VoiceSettingsButton" Content="🎤   Voice Settings" Height="48" Margin="0,0,0,24"
                    Click="VoiceSettingsButton_Click" HorizontalContentAlignment="Left" Padding="16,0" FontWeight="Bold"
                    Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}" BorderThickness="0"/>

            <TextBlock Text="UPDATES" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>
            <TextBlock x:Name="UpdateStatusText" FontSize="12" TextWrapping="Wrap"
                       Foreground="{StaticResource TextMuted}" Margin="0,0,0,12"/>

            <Button x:Name="CheckForUpdateButton" Content="Check for Update" Height="40" Margin="0,0,0,10"
                    Click="CheckForUpdateButton_Click"
                    Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}" BorderThickness="0"/>
            <Button x:Name="InstallUpdateButton" Content="Install Update" Height="40"
                    Click="InstallUpdateButton_Click" Visibility="Collapsed" FontWeight="Bold"
                    Background="{StaticResource AccentBlurple}" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
