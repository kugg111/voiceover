<ui:FluentWindow x:Class="Voiceover.Client.Views.InvitesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Invites" Height="420" Width="380"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgDark}"
        Icon="/Assets/AppIcon.png"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Invites" Grid.Row="0" ShowMaximize="False"/>

        <DockPanel Grid.Row="1" Margin="20">
            <Button DockPanel.Dock="Top" x:Name="GenerateButton" Content="Generate New Invite" Height="40" Margin="0,0,0,16"
                    Click="GenerateButton_Click"
                    Background="{StaticResource AccentBlurple}" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand"/>

            <TextBlock DockPanel.Dock="Top" Text="ACTIVE INVITES" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>

            <TextBlock DockPanel.Dock="Top" x:Name="EmptyStateText" Text="No active invites yet - generate one above."
                       FontSize="12" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}"
                       Visibility="Collapsed" Margin="0,0,0,8"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="InviteList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource BgSidebar}" CornerRadius="4" Padding="10,8" Margin="0,0,0,8"
                                    Cursor="Hand" MouseLeftButtonUp="InviteRow_MouseLeftButtonUp">
                                <StackPanel>
                                    <TextBlock Text="{Binding Code}" FontWeight="Bold" FontSize="14"
                                               Foreground="{StaticResource TextNormal}"/>
                                    <TextBlock Text="{Binding Details}" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</ui:FluentWindow>
