<ui:FluentWindow x:Class="Voiceover.Client.Views.InvitesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Invites" Height="420" Width="380"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgDark}"
        Icon="/Assets/AppIcon.png"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Invites" Grid.Row="0" ShowMaximize="False"/>

        <DockPanel Grid.Row="1" Margin="20">
            <Button DockPanel.Dock="Top" x:Name="GenerateButton" Content="Generate New Invite" Height="40" Margin="0,0,0,16"
                    Click="GenerateButton_Click"
                    Background="{StaticResource AccentBlurple}" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand"/>

            <TextBlock DockPanel.Dock="Top" Text="ACTIVE INVITES" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>

            <TextBlock DockPanel.Dock="Top" x:Name="EmptyStateText" Text="No active invites yet - generate one above."
                       FontSize="12" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}"
                       Visibility="Collapsed" Margin="0,0,0,8"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="InviteList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource BgSidebar}" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Code}" FontWeight="Bold" FontSize="14"
                                                   Foreground="{StaticResource TextNormal}"/>
                                        <TextBlock Text="{Binding Details}" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                    </StackPanel>
                                    <!-- Vector icons, not emoji glyphs - emoji font fallback rendered as a
                                         garbled tofu box in some environments, this doesn't depend on any font. -->
                                    <Button Grid.Column="1" Width="32" Height="32" Tag="{Binding Code}"
                                            Click="CopyButton_Click" ToolTip="Copy to clipboard"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center">
                                        <Grid>
                                            <Viewbox Width="14" Height="14" Visibility="{Binding CopyIconVisibility}">
                                                <Canvas Width="24" Height="24">
                                                    <Rectangle Canvas.Left="9" Canvas.Top="2" Width="11" Height="13" RadiusX="2" RadiusY="2"
                                                               Stroke="{StaticResource TextNormal}" StrokeThickness="1.6" Fill="Transparent"/>
                                                    <Rectangle Canvas.Left="4" Canvas.Top="7" Width="11" Height="13" RadiusX="2" RadiusY="2"
                                                               Fill="{StaticResource BgSidebar}" Stroke="{StaticResource TextNormal}" StrokeThickness="1.6"/>
                                                </Canvas>
                                            </Viewbox>
                                            <Viewbox Width="16" Height="16" Visibility="{Binding CheckIconVisibility}">
                                                <Canvas Width="24" Height="24">
                                                    <Polyline Points="3,13 9,19 21,5" Stroke="#3BA55D" StrokeThickness="2.5"
                                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"/>
                                                </Canvas>
                                            </Viewbox>
                                        </Grid>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</ui:FluentWindow>
