<Window x:Class="DiscordClone.Client.Views.DirectMessageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Direct Messages" Height="520" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgDark}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: user search -->
        <DockPanel Grid.Column="0" Background="{StaticResource BgSidebar}" Margin="0">
            <TextBox DockPanel.Dock="Top" x:Name="SearchBox" Height="34" Margin="10"
                     Background="{StaticResource BgDarker}" Foreground="{StaticResource TextNormal}"
                     BorderThickness="0" Padding="8,6" TextChanged="SearchBox_TextChanged"
                     Tag="Search a username..."/>
            <ScrollViewer>
                <ItemsControl x:Name="SearchResultsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Username}" Tag="{Binding Id}" Click="UserResult_Click"
                                    HorizontalContentAlignment="Left" Background="Transparent"
                                    Foreground="{StaticResource TextNormal}" BorderThickness="0" Padding="10,8"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <!-- RIGHT: conversation -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="ConversationHeader" Grid.Row="0" Text="Select someone to message"
                       Foreground="{StaticResource TextNormal}" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="16,0,0,0"/>

            <ScrollViewer Grid.Row="1" x:Name="DmScroll" Padding="16,8">
                <ItemsControl x:Name="DmMessageList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,6,0,6">
                                <TextBlock Text="{Binding AuthorLabel}" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBlurple}"/>
                                <TextBlock Text="{Binding Content}" Foreground="{StaticResource TextNormal}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Grid Grid.Row="2" Margin="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="DmInput" Height="38" Padding="8,8" VerticalContentAlignment="Center"
                         Background="{StaticResource BgSidebar}" Foreground="{StaticResource TextNormal}"
                         BorderThickness="0" KeyDown="DmInput_KeyDown"/>
                <Button Grid.Column="1" Content="Send" Width="70" Height="38" Margin="8,0,0,0"
                        Background="{StaticResource AccentBlurple}" Foreground="White" BorderThickness="0"
                        Click="SendDmButton_Click"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
