<Window x:Class="Voiceover.Client.Views.ToastNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize"
        Width="320" SizeToContent="Height"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border Background="#232428" CornerRadius="10" Padding="14"
            BorderBrush="#5865F2" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="16" ShadowDepth="4" Opacity="0.4"/>
        </Border.Effect>
        <StackPanel>
            <TextBlock x:Name="TitleText" FontWeight="Bold" FontSize="14" Foreground="White" TextWrapping="Wrap"/>
            <TextBlock x:Name="MessageText" FontSize="12" Foreground="#949BA4" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>
    </Border>
</Window>
