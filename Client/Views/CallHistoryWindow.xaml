<ui:FluentWindow x:Class="Voiceover.Client.Views.CallHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:Voiceover.Client.Views"
        Title="Recent Calls" Height="480" Width="380"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgDark}"
        Icon="/Assets/AppIcon.png"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Recent Calls" Grid.Row="0" ShowMaximize="False"/>

        <DockPanel Grid.Row="1" Margin="20">
            <TextBlock DockPanel.Dock="Top" x:Name="EmptyStateText" Text="No calls yet."
                       FontSize="12" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}"
                       Visibility="Collapsed" Margin="0,0,0,8"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="CallList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource BgSidebar}" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <local:AvatarView Grid.Column="0" Size="32" DisplayName="{Binding OtherUsername}"
                                                       ImageUrl="{Binding OtherUserAvatarUrl}" Margin="0,0,10,0"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding OtherUsername}" FontWeight="Bold" FontSize="14"
                                                   Foreground="{StaticResource TextNormal}"/>
                                        <TextBlock Text="{Binding Summary}" FontSize="11"
                                                   Foreground="{Binding SummaryColor}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding TimeDisplay}" FontSize="11"
                                               Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</ui:FluentWindow>
