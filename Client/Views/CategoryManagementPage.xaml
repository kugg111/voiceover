<UserControl x:Class="Voiceover.Client.Views.CategoryManagementPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="AddCategoryButton" Content="Add Category" Click="AddCategoryButton_Click"
                    Padding="10,6" Background="{StaticResource AccentBlurple}" Foreground="White" BorderThickness="0"/>
        </StackPanel>

        <TextBlock DockPanel.Dock="Top" x:Name="EmptyStateText" Text="No categories yet."
                   FontSize="12" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}"
                   Visibility="Collapsed" Margin="0,0,0,8"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="CategoryList" MaxWidth="480" HorizontalAlignment="Left">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource BgSidebar}" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"
                                           FontSize="13" Foreground="{StaticResource TextNormal}"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="▲" Tag="{Binding Id}" Click="MoveUpButton_Click" ToolTip="Move Up"
                                            Width="26" Height="26" Padding="0" Margin="0,0,4,0"
                                            Background="{StaticResource BgDarker}" Foreground="{StaticResource TextNormal}"
                                            BorderThickness="0" Cursor="Hand"/>
                                    <Button Content="▼" Tag="{Binding Id}" Click="MoveDownButton_Click" ToolTip="Move Down"
                                            Width="26" Height="26" Padding="0" Margin="0,0,4,0"
                                            Background="{StaticResource BgDarker}" Foreground="{StaticResource TextNormal}"
                                            BorderThickness="0" Cursor="Hand"/>
                                    <Button Content="Rename" Tag="{Binding Id}" Click="RenameButton_Click"
                                            Padding="8,4" FontSize="11" Margin="0,0,4,0"
                                            Background="{StaticResource BgDarker}" Foreground="{StaticResource TextNormal}"
                                            BorderThickness="0" Cursor="Hand"/>
                                    <Button Content="Delete" Tag="{Binding Id}" Click="DeleteButton_Click"
                                            Padding="8,4" FontSize="11"
                                            Background="{StaticResource BgDarker}" Foreground="{StaticResource TextNormal}"
                                            BorderThickness="0" Cursor="Hand"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
